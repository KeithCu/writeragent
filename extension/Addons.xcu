<?xml version="1.0" encoding="UTF-8"?>
<oor:component-data xmlns:oor="http://openoffice.org/2001/registry" xmlns:xs="http://www.w3.org/2001/XMLSchema" oor:name="Addons" oor:package="org.openoffice.Office">
  <node oor:name="AddonUI">
    <node oor:name="OfficeMenuBar">
      <node oor:name="org.extension.writeragent.menubar" oor:op="replace">
        <prop oor:name="Title" oor:type="xs:string">
          <value xml:lang="en-US">WriterAgent</value>
        </prop>
        <prop oor:name="Context" oor:type="xs:string">
          <value>com.sun.star.sheet.SpreadsheetDocument,com.sun.star.text.GlobalDocument,com.sun.star.text.TextDocument,com.sun.star.text.WebDocument,com.sun.star.drawing.DrawingDocument,com.sun.star.presentation.PresentationDocument</value>
        </prop>
        <node oor:name="Submenu">
          <node oor:name="M1" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Extend Selection</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:chatbot.extend_selection</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
           <node oor:name="M2" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Edit Selection</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:chatbot.edit_selection</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
             <node oor:name="M3" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Settings</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:main.settings</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3b" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Toggle MCP Server</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:mcp.toggle_server</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3c" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">MCP Server Status</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:mcp.server_status</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3d" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Run Python Script...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:scripting.run_python_dialog</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3d_vision" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Vision OCR Settings...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:vision.open_settings</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3d_py_cell" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Edit Python in Cell...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:scripting.edit_python_cell</value>
            </prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>

          <node oor:name="M3d_py_reset" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Reset Python Session</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:scripting.reset_python_session</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3d_convert_sheet" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Convert Sheet to Python...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:calc.convert_spreadsheet_to_python</value>
            </prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.sheet.SpreadsheetDocument</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3d_nb" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Import Jupyter Notebook...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:scripting.import_ipynb</value>
            </prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.text.TextDocument</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M3e" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Insert LaTeX Math...</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:writer.insert_latex_dialog</value>
            </prop>
            <prop oor:name="Context" oor:type="xs:string">
              <value>com.sun.star.text.TextDocument</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
          </node>
          <node oor:name="M_Debug" oor:op="replace">
            <prop oor:name="Title">
              <value xml:lang="en-US">Debug</value>
            </prop>
            <prop oor:name="URL">
              <value>org.extension.writeragent:main.NoOp</value>
            </prop>
            <prop oor:name="Target" oor:type="xs:string">
              <value>_self</value>
            </prop>
            <node oor:name="Submenu">
              <node oor:name="M4" oor:op="replace">
                <prop oor:name="Title">
                  <value xml:lang="en-US">Run format tests</value>
                </prop>
                <prop oor:name="URL">
                  <value>org.extension.writeragent:main.RunFormatTests</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                  <value>_self</value>
                </prop>
              </node>
              <node oor:name="M5" oor:op="replace">
                <prop oor:name="Title">
                  <value xml:lang="en-US">Run calc tests</value>
                </prop>
                <prop oor:name="URL">
                  <value>org.extension.writeragent:main.RunCalcTests</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                  <value>_self</value>
                </prop>
              </node>
              <node oor:name="M6" oor:op="replace">
                <prop oor:name="Title">
                  <value xml:lang="en-US">Run Calc API integration tests</value>
                </prop>
                <prop oor:name="URL">
                  <value>org.extension.writeragent:main.RunCalcIntegrationTests</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                  <value>_self</value>
                </prop>
              </node>
              <node oor:name="M7" oor:op="replace">
                <prop oor:name="Title">
                  <value xml:lang="en-US">Run draw tests</value>
                </prop>
                <prop oor:name="URL">
                  <value>org.extension.writeragent:main.RunDrawTests</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                  <value>_self</value>
                </prop>
              </node>
              <node oor:name="M8" oor:op="replace">
                <prop oor:name="Title">
                  <value xml:lang="en-US">Evaluation Dashboard</value>
                </prop>
                <prop oor:name="URL">
                  <value>org.extension.writeragent:main.EvaluationDashboard</value>
                </prop>
                <prop oor:name="Target" oor:type="xs:string">
                  <value>_self</value>
                </prop>
              </node>
            </node>
          </node>
        </node>
      </node>
    </node>
  </node>
</oor:component-data>

