<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dlg:window PUBLIC "-//OpenOffice.org//DTD OfficeDocument 1.0//EN" "dialog.dtd">
<dlg:window xmlns:dlg="http://openoffice.org/2000/dialog" xmlns:script="http://openoffice.org/2000/script"
  dlg:id="PythonTestProgressDialog" dlg:left="100" dlg:top="50" dlg:width="320" dlg:height="285"
  dlg:closeable="true" dlg:moveable="true" dlg:title="Python Test">
 <dlg:bulletinboard>
  <dlg:text dlg:id="StatusLbl" dlg:left="8" dlg:top="8" dlg:width="304" dlg:height="12" dlg:value="Testing Python environment..." dlg:align="left" dlg:multiline="false"/>
  <dlg:textfield dlg:id="LogArea" dlg:left="8" dlg:top="24" dlg:width="304" dlg:height="225" dlg:tabstop="true" dlg:readonly="true" dlg:multiline="true" dlg:vscroll="true"/>
  <dlg:button dlg:id="BtnClose" dlg:left="252" dlg:top="255" dlg:width="60" dlg:height="14" dlg:value="Close" dlg:tabstop="true"/>
 </dlg:bulletinboard>
</dlg:window>
