<?xml version="1.0" encoding="UTF-8"?>
<!-- Locales must match ``GRAMMAR_REGISTRY_LOCALE_TAGS`` in ``grammar_locale_registry`` (Lightproof-style). -->
<oor:component-data oor:name="Linguistic"
        oor:package="org.openoffice.Office" xmlns:oor="http://openoffice.org/2001/registry"
        xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <node oor:name="ServiceManager">
        <node oor:name="GrammarCheckers">
            <node oor:name="org.extension.writeragent.comp.pyuno.AiGrammarProofreader" oor:op="fuse">
                <prop oor:name="Locales" oor:type="oor:string-list">
                    <value>en-US en-GB bg-BG bn-IN ca-ES cs-CZ da-DK de-DE el-GR es-ES et-EE fi-FI fr-FR hi-IN hr-HR hu-HU id-ID it-IT ja-JP ko-KR lt-LT lv-LV nb-NO nl-NL nn-NO pl-PL pt-BR ro-RO ru-RU sk-SK sv-SE tr-TR uk-UA ur-PK zh-CN zh-TW</value>
                </prop>
            </node>
        </node>
    </node>
</oor:component-data>
