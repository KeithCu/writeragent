<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dlg:window PUBLIC "-//OpenOffice.org//DTD OfficeDocument 1.0//EN" "dialog.dtd">
<dlg:window xmlns:dlg="http://openoffice.org/2000/dialog" xmlns:script="http://openoffice.org/2000/script"
  dlg:id="SearchDialog" dlg:left="100" dlg:top="50" dlg:width="350" dlg:height="270"
  dlg:closeable="true" dlg:moveable="true" dlg:title="Search Nearby Files">
 <dlg:bulletinboard>
  <dlg:text dlg:id="QueryLbl" dlg:left="8" dlg:top="8" dlg:width="80" dlg:height="10" dlg:value="Search Query:" dlg:align="left" dlg:multiline="false"/>
  <dlg:textfield dlg:id="QueryEdit" dlg:left="8" dlg:top="20" dlg:width="334" dlg:height="14" dlg:tabstop="true"/>
  <dlg:text dlg:id="RespLbl" dlg:left="8" dlg:top="38" dlg:width="100" dlg:height="10" dlg:value="Number of Responses:" dlg:align="left" dlg:multiline="false"/>
  <dlg:textfield dlg:id="RespEdit" dlg:left="112" dlg:top="36" dlg:width="30" dlg:height="14" dlg:tabstop="true" dlg:value="7"/>
  <dlg:text dlg:id="CacheStatusLbl" dlg:left="8" dlg:top="56" dlg:width="334" dlg:height="10" dlg:value="Cache Status: Checking..." dlg:align="left" dlg:multiline="false"/>
  <dlg:button dlg:id="BtnSearch" dlg:left="8" dlg:top="72" dlg:width="50" dlg:height="14" dlg:value="Search" dlg:tabstop="true"/>
  <dlg:button dlg:id="BtnRebuild" dlg:left="64" dlg:top="72" dlg:width="50" dlg:height="14" dlg:value="Rebuild" dlg:tabstop="true"/>
  <dlg:button dlg:id="BtnCancel" dlg:left="120" dlg:top="72" dlg:width="50" dlg:height="14" dlg:value="Close" dlg:tabstop="true"/>
  <dlg:text dlg:id="ResultsLbl" dlg:left="8" dlg:top="92" dlg:width="50" dlg:height="10" dlg:value="Results:" dlg:align="left" dlg:multiline="false"/>
  <dlg:textfield dlg:id="ResultsEdit" dlg:left="8" dlg:top="104" dlg:width="334" dlg:height="158" dlg:tabstop="true" dlg:readonly="true" dlg:multiline="true" dlg:vscroll="true"/>
 </dlg:bulletinboard>
</dlg:window>
