<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dlg:window PUBLIC "-//OpenOffice.org//DTD OfficeDocument 1.0//EN" "dialog.dtd">
<dlg:window xmlns:dlg="http://openoffice.org/2000/dialog" xmlns:script="http://openoffice.org/2000/script"
  dlg:id="LatexInputDialog" dlg:left="100" dlg:top="50" dlg:width="350" dlg:height="180"
  dlg:closeable="true" dlg:moveable="true" dlg:title="Insert LaTeX Math">
 <dlg:bulletinboard>
  <dlg:text dlg:id="InstructionLbl" dlg:left="8" dlg:top="8" dlg:width="334" dlg:height="12" dlg:value="Enter LaTeX math code to convert and insert as formula:" dlg:align="left" dlg:multiline="false"/>
  <dlg:textfield dlg:id="LatexEdit" dlg:left="8" dlg:top="24" dlg:width="334" dlg:height="100" dlg:tabstop="true" dlg:value="" dlg:multiline="true" dlg:vscroll="true"/>
  <dlg:checkbox dlg:id="DisplayBlockCheck" dlg:left="8" dlg:top="130" dlg:width="334" dlg:height="14" dlg:tabstop="true" dlg:value="Insert as display block (centered paragraph)"/>
  <dlg:button dlg:id="BtnInsert" dlg:left="220" dlg:top="154" dlg:width="60" dlg:height="14" dlg:value="Insert" dlg:tabstop="true"/>
  <dlg:button dlg:id="BtnCancel" dlg:left="286" dlg:top="154" dlg:width="56" dlg:height="14" dlg:value="Close" dlg:tabstop="true"/>
 </dlg:bulletinboard>
</dlg:window>
