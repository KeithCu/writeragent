#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Belge araştırması okumaları özel görev delegasyonu (USE_SUB_AGENT) "
"gerektirir. Bunu yapılandırmadan etkinleştirin."

#: plugin/doc/specialized_base.py
#, python-brace-format
