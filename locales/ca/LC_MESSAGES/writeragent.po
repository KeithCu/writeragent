#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Les lectures de recerca de documents requereixen una delegació de tasques "
"especialitzada (USE_SUB_AGENT). Habiliteu-ho a la configuració."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"La crida a l'eina ha canviat a «{0}». Esteu en un mode d'eines "
"especialitzat. Heu de cridar «specialized_workflow_finished» quan hàgiu "
"acabat per restaurar el conjunt complet d'API."

