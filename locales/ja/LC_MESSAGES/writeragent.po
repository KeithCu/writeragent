#: plugin/xdl_strings.py
msgid "WriterAgent Evaluation Dashboard"
msgstr "WriterAgent 評価ダッシュボード"

msgid "Agent Communication Protocol"
msgstr "エージェント通信プロトコル"

msgid "Backend"
msgstr "バックエンド"

msgid "Built-in"
msgstr "ビルトイン"

msgid "Hermes"
msgstr "Hermes"

msgid "Claude Code (ACP)"
msgstr "Claude Code (ACP)"

msgid "Mistral Vibe (ACP)"
msgstr "ミストラル・バイブ (ACP)"

msgid "Grok Build (ACP)"
msgstr "Grok Build (ACP)"

msgid "Path / URL"
msgstr "パス / URL"

msgid ""
"Path to backend CLI (e.g. aider) or ACP server URL (e.g. "
"http://localhost:8000 for Hermes). Empty = try default."
msgstr ""
"バックエンド CLI のパス (例: aider)、または ACP サーバーの URL (例: Hermes の場合は "
"http://localhost:8000)。空の場合はデフォルトを試行します。"

msgid "Extra arguments"
msgstr "追加引数"

msgid "Optional arguments for the selected backend (space-separated)."
msgstr "選択したバックエンドのオプション引数 (スペース区切り)。"

msgid "ACP agent name"
msgstr "ACP エージェント名"

msgid ""
"Agent name on the ACP server (e.g. hermes). Empty = auto-discover first "
"agent."
msgstr "ACP サーバー上のエージェント名 (例: hermes)。空の場合は最初のエージェントを自動検出します。"

msgid "Calc spreadsheet tools"
msgstr "Calc 表計算ツール"

msgid "Max Rows Display"
msgstr "最大表示行数"

msgid "Sidebar"
msgstr "サイドバー"

msgid "Max Tool Rounds"
msgstr "最大ツールラウンド数"

msgid "Document Context Strategy"
msgstr "ドキュメント コンテキスト戦略"

msgid "How much document content to include in LLM context"
msgstr "LLM コンテキストに含めるドキュメントコンテンツの量"

msgid "Auto (by document size)"
msgstr "自動 (ドキュメントサイズによる)"

msgid "Full document text"
msgstr "ドキュメント全文"

msgid "Pages around cursor"
msgstr "カーソル周辺のページ"

msgid "Outline + excerpt"
msgstr "アウトライン + 抜粋"

msgid "Stats + outline only"
msgstr "統計情報 + アウトラインのみ"

msgid "Extend max tokens"
msgstr "最大トークン数を拡張"

msgid "Edit extra tokens"
msgstr "追加トークンを編集"

msgid "Extra tokens beyond original text length. 0 = same length as original."
msgstr "元のテキスト長に追加するトークン数。0 = 元と同じ長さ。"

msgid "Web Research Cache"
msgstr "Web Research Cache"

msgid ""
"Cache completed web research reports by normalized query (uses web cache "
"database)."
msgstr "完了したWeb調査レポートを正規化されたクエリでキャッシュします (Webキャッシュデータベースを使用)。"

msgid "Prompt for Web Research"
msgstr "ウェブ調査用プロンプト"

msgid "Ask for confirmation before sending a web search query"
msgstr "ウェブ検索クエリを送信する前に確認を求める"

msgid "Web Research Browser"
msgstr "Web Research Browser"

msgid ""
"Select the browser backend to use for webpage visits during research (Off "
"uses static HTTP requests)."
msgstr "リサーチ時にウェブページを閲覧するためのブラウザバックエンドを選択します（「オフ」は静的なHTTPリクエストを使用します）。"

msgid "Off (Static HTTP)"
msgstr "オフ (静的HTTP)"

msgid "Firefox (CDP)"
msgstr "Firefox (CDP)"

msgid "Chromium (CDP)"
msgstr "Chromium (CDP)"

msgid "Chrome (CDP)"
msgstr "Chrome (CDP)"

msgid "Cache max (MB)"
msgstr "キャッシュ最大サイズ (MB)"

msgid "Max disk size for web search cache (0 to disable)"
msgstr "Web 検索キャッシュの最大ディスクサイズ (0 で無効化)"

msgid "Cache validity (days)"
msgstr "キャッシュ有効期間 (日)"

msgid "How many days cache entries should be considered valid."
msgstr "キャッシュエントリが有効と見なされる日数。"

msgid "Rich Text Control Sidebar"
msgstr "リッチテキストコントロールサイドバー"

msgid "Formatted chat via RichTextControl. Requires restart."
msgstr "RichTextControl を介した書式付きチャット。再起動が必要です。"

msgid "Humanizer skill (natural prose)"
msgstr "ヒューマナイザースキル (自然な文章)"

msgid ""
"When enabled, injects guidance into the system prompt so the model makes "
"generated or revised document text sound more natural and human (removes AI "
"slop patterns). Edit the rules in your LibreOffice profile under "
"writeragent/skills/humanizer/SKILL.md (the file is auto-created on first "
"use). A dedicated Skills tab can be added later."
msgstr ""
"有効にすると、生成または修正された文書のテキストがより自然で人間らしく聞こえるように（AI特有の不自然なパターンを除去）、システムプロンプトにガイダンスを注入します。ルールを編集するには、LibreOfficeプロファイルの"
" writeragent/skills/humanizer/SKILL.md "
"を開いてください（このファイルは初回使用時に自動作成されます）。専用の「スキル」タブは後日追加される予定です。"

msgid "Doc"
msgstr "文書"

msgid "Enable AI grammar checker (Writer)"
msgstr "AI 文法チェッカー (Writer) を有効にする"

msgid ""
"When on, WriterAgent registers its AI grammar proofreader with Linguistic; "
"checked text uses your API (Tools → Options → AI). Underlines appear shortly"
" after you pause typing. Off by default."
msgstr ""
"オンにすると、WriterAgent は Linguistic に AI 文法校正機能を登録します。チェックされるテキストはあなたの API "
"を使用します (Tools → Options → AI)。入力が一時停止するとすぐに下線が表示されます。デフォルトでオフです。"

msgid "Model (optional)"
msgstr "モデル (オプション)"

msgid "Leave empty to use the same text model as chat."
msgstr "チャットと同じテキストモデルを使用するには空にしておいてください。"

msgid "Pause grammar while chat/agent runs"
msgstr "チャット/エージェント実行中に文法を一時停止"

msgid ""
"When on, AI grammar skips background requests while sidebar chat or agent "
"runs, to avoid concurrent API calls."
msgstr ""
"オンにすると、サイドバーチャットまたはエージェント実行中は同時 API 呼び出しを避けるため、AI 文法のバックグラウンドリクエストをスキップします。"

msgid "Batch sentences"
msgstr "バッチ文"

msgid ""
"Number of sentences to send per LLM request (1-8). 1 (default) is most "
"reliable; higher values are faster and cheaper but may hit token limits or "
"cause model errors."
msgstr ""
"LLMリクエストごとに送信する文の数 (1～8)。1 (デフォルト) "
"が最も確実です。値を大きくすると高速かつ低コストになりますが、トークン制限に達したり、モデルエラーが発生したりする可能性があります。"

msgid "Concurrent requests"
msgstr "同時リクエスト数"

msgid ""
"Max simultaneous background grammar API calls (1-8). 1 matches prior "
"behavior. Raise for OpenRouter or other providers that allow parallel "
"requests; use with care alongside sidebar chat."
msgstr ""
"バックグラウンドでのGrammar "
"API同時呼び出し数（1～8）。1は従来の動作と同じです。OpenRouterや並列リクエストを許可する他のプロバイダーを使用する場合は増やしてください。サイドバーチャットと併用する場合は注意してください。"

msgid "Sentence language detection"
msgstr "文の言語検出"

msgid ""
"Verify each complete sentence's language against the document locale. AI "
"uses your grammar/chat API; Local uses bundled langdetect (no API call, no "
"venv). Mismatches update CharLocale and re-check grammar."
msgstr ""
"各完全な文の言語をドキュメントの言語設定と照合して検証します。AIは文法/チャットAPIを使用し、Localはバンドルされたlangdetectを使用します（API呼び出しや仮想環境は不要）。不一致がある場合、CharLocaleを更新して文法を再チェックします。"

msgid "Off"
msgstr "オフ"

msgid "AI (LLM)"
msgstr "AI (LLM)"

msgid "Local (langdetect)"
msgstr "ローカル (langdetect)"

msgid "Enter key sends sidebar chat message"
msgstr "Enterキーでサイドバーのチャットメッセージを送信"

msgid ""
"When on, Enter in the sidebar query runs the same action as Send; "
"Shift+Enter inserts a newline. When off, Enter inserts a newline."
msgstr ""
"オンにすると、サイドバーのクエリ入力欄でEnterキーを押すと「送信」と同じ動作になり、Shift+Enterで改行が挿入されます。オフにすると、Enterキーで改行が挿入されます。"

msgid "Agent edit review"
msgstr "エージェント編集レビュー"

msgid ""
"Off = direct edits. Record = tracked changes you accept/reject yourself. "
"Wait = apply_document_content blocks (on chat/MCP worker thread) until you "
"review."
msgstr ""
"オフ = 直接編集。記録 = 変更履歴として記録し、自身で承諾/拒否。待機 = レビューするまで apply_document_content "
"をブロック（チャット/MCPワーカー・スレッド上）。"

msgid "Record (track changes)"
msgstr "記録 (変更履歴)"

msgid "Wait for review"
msgstr "レビュー待ち"

msgid "Draw and Impress tools"
msgstr "Draw と Impress ツール"

msgid "Vector Search"
msgstr "ベクトル検索"

msgid "Cross-file search"
msgstr "ファイル横断検索"

msgid ""
"Indexed semantic + keyword search for document_research (corpus.db). "
"Requires embeddings venv — see Python Test."
msgstr ""
"document_research (corpus.db) 用のインデックス化されたセマンティック + キーワード検索。埋め込み用 venv が必要 —"
" Python テストを参照。"

msgid "Embeddings + FTS"
msgstr "埋め込み + FTS"

msgid "LlamaIndex"
msgstr "LlamaIndex"

msgid "Zvec (experimental)"
msgstr "Zvec (実験的)"

msgid "LanceDB (experimental)"
msgstr "LanceDB (実験的)"

msgid "Embedding Model"
msgstr "埋め込みモデル"

msgid "HuggingFace model ID for local provider, or endpoint-specific model ID"
msgstr "ローカルプロバイダー用のHuggingFaceモデルID、またはエンドポイント固有のモデルID"

msgid "Enable cross-file rerank"
msgstr "ファイル横断リランクを有効にする"

msgid ""
"Second-stage cross-encoder after hybrid retrieve (Embeddings + FTS and "
"LlamaIndex). Off by default."
msgstr ""
"ハイブリッド検索（埋め込みベクトル + FTS および LlamaIndex）後のセカンドステージ・クロスエンコーダー。デフォルトではオフ。"

msgid "Rerank model"
msgstr "リランクモデル"

msgid ""
"Used only when rerank is enabled. English MiniLM is fast; bge-reranker-v2-m3"
" is multilingual and downloads ~2.3 GB."
msgstr ""
"リランクが有効な場合のみ使用されます。English MiniLMは高速ですが、bge-"
"reranker-v2-m3は多言語対応で約2.3GBのダウンロードが必要です。"

msgid "cross-encoder/ms-marco-MiniLM-L-6-v2"
msgstr "cross-encoder/ms-marco-MiniLM-L-6-v2"

msgid "BAAI/bge-reranker-v2-m3"
msgstr "BAAI/bge-reranker-v2-m3"

msgid "Core services (config, events, logging)"
msgstr "コアサービス (設定、イベント、ログ)"

msgid "MCP"
msgstr "MCP"

msgid "Enable MCP Server"
msgstr "MCP サーバーを有効にする"

msgid ""
"Localhost only, no auth. Clients use http://localhost:<port>/mcp (streamable"
" HTTP)."
msgstr ""
"ローカルホストのみ、認証なし。クライアントは http://localhost:<port>/mcp (ストリーミング可能なHTTP) を使用します。"

msgid "MCP Port"
msgstr "MCP ポート"

msgid "Python"
msgstr "Python"

msgid "Python venv path"
msgstr "Python仮想環境(venv)のパス"

msgid ""
"If set, runs tools in that venv (bin/python or Scripts/python.exe). If "
"empty, run_venv_python_script uses this process's sys.executable (basic "
"stdlib); use a venv for numpy/pandas and Vision Helpers (paddleocr, "
"paddlepaddle)."
msgstr ""
"設定されている場合、その仮想環境 (bin/python または Scripts/python.exe) "
"でツールを実行します。空の場合、run_venv_python_script はこのプロセスの sys.executable (基本的な標準ライブラリ)"
" を使用します。numpy/pandas およびビジョンヘルパー (paddleocr, paddlepaddle) "
"を使用する場合は仮想環境を指定してください。"

msgid "Test"
msgstr "テスト"

msgid "Python script timeout (seconds)"
msgstr "Python スクリプトのタイムアウト（秒）"

msgid ""
"Wall-clock limit for Run Python Script, =PYTHON(), and "
"run_venv_python_script."
msgstr ""
"「Python スクリプトの実行」、=PYTHON()、および run_venv_python_script の実行時間制限（ウォールクロック時間）"

msgid "Max Calc data cells"
msgstr "Calcの最大データセル数"

msgid ""
"Maximum cells in =PYTHON() data or Run Python Script data/data_range. Larger"
" values use more RAM and time; UNO range read still dominates."
msgstr ""
"=PYTHON() データまたは「Pythonスクリプトを実行」の data/data_range "
"における最大セル数。値を大きくするとメモリと時間を消費します。UNO範囲の読み取りが依然として支配的です。"

msgid "Python session mode"
msgstr "Pythonセッションモード"

msgid ""
"Isolated: each =PYTHON() cell gets a fresh namespace. Shared: one namespace "
"per workbook (variables carry between cells)."
msgstr ""
"分離モード: 各 =PYTHON() セルは独立した名前空間を持ちます。共有モード: "
"ブックごとに1つの名前空間を共有します（変数がセル間で引き継がれます）。"

msgid "Isolated (default)"
msgstr "分離モード (デフォルト)"

msgid "Shared kernel"
msgstr "共有カーネル"

msgid "Python auto spill in Calc"
msgstr "Calc での Python 自動スピル"

msgid ""
"Automatically spill multi-cell array/DataFrame results from =PYTHON() into "
"adjacent cells."
msgstr "=PYTHON() の複数セル配列/DataFrame の結果を隣接するセルに自動的にスピルします。"

msgid "Vision / OCR"
msgstr "ビジョン / OCR"

msgid "Image scale"
msgstr "画像の拡大率"

msgid "Upscale before OCR/layout. Try 2.0 for small screenshots."
msgstr "OCR/レイアウト解析前に画像を拡大します。小さなスクリーンショットには2.0を試してください。"

msgid "Worker timeout (seconds)"
msgstr "ワーカーのタイムアウト（秒）"

msgid "Host subprocess limit for Vision Helpers (first model download)."
msgstr "Vision Helper（初回モデルダウンロード）のホストサブプロセス制限。"

msgid "Docling artifacts path"
msgstr "Doclingアーティファクトのパス"

msgid "Optional folder from docling-tools models download (offline use)."
msgstr "docling-toolsモデルダウンロード用のオプションフォルダ（オフライン使用）。"

msgid "OCR confidence threshold"
msgstr "OCR信頼度しきい値"

msgid "RapidOCR minimum text score. Raise to reduce garbage text."
msgstr "RapidOCRの最小テキストスコア。値を上げると不要なテキストを減らせます。"

msgid "OCR entire image"
msgstr "画像全体をOCR"

msgid "Recommended for embedded graphics exported from LibreOffice."
msgstr "LibreOfficeからエクスポートされた埋め込みグラフィックに推奨。"

msgid "Table extraction mode"
msgstr "テーブル抽出モード"

msgid "Accurate (default)"
msgstr "高精度 (デフォルト)"

msgid "Fast"
msgstr "高速"

msgid "Table cell matching"
msgstr "表セルのマッチング"

msgid "Align detected table cells with content (extract_structure)."
msgstr "検出された表セルをコンテンツに合わせる (extract_structure)"

msgid "Keep orphan text clusters"
msgstr "孤立したテキストクラスターを保持"

msgid "Group unassigned text into clusters for messy layouts."
msgstr "複雑なレイアウトのために未割り当てのテキストをクラスターにグループ化"

msgid "Document insert mode"
msgstr "ドキュメント挿入モード"

msgid ""
"html = Docling HTML import (default). structured = bbox column layout in "
"Writer; native Calc cells for extract_structure tables."
msgstr ""
"html = Docling HTML インポート (デフォルト)。structured = Writer での bbox "
"カラムレイアウト。構造抽出テーブルにはネイティブの Calc セルを使用。"

msgid "Standard HTML"
msgstr "標準 HTML"

msgid "Structured (layout / cell grid)"
msgstr "構造化 (レイアウト / セルグリッド)"

msgid "Layout model"
msgstr "レイアウトモデル"

msgid "Heron (default)"
msgstr "Heron (デフォルト)"

msgid "Egret large (slower"
msgstr "Egret large (低速"

msgid "Extract formulas (LaTeX)"
msgstr "数式を抽出 (LaTeX)"

msgid "Opt-in. Downloads extra VLM models on first use; slower."
msgstr "オプトイン。初回使用時に追加のVLMモデルをダウンロードします（低速）。"

msgid "Code block enrichment"
msgstr "コードブロックの強化"

msgid "Specialized OCR for code/terminal screenshots."
msgstr "コードやターミナルのスクリーンショットに特化したOCR。"

msgid "Docling document timeout (s)"
msgstr "Doclingドキュメントのタイムアウト（秒）"

msgid "Per-conversion timeout inside Docling. 0 = no limit."
msgstr "Docling内での変換ごとのタイムアウト。0は制限なし。"
