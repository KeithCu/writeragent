#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"ডকুমেন্ট গবেষণার জন্য সাব-এজেন্ট ডেলিগেশন (USE_SUB_AGENT) প্রয়োজন। "
"কনফিগারেশনে সাব-এজেন্ট সক্রিয় করুন।"

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"টুল কল '{0}'-এ পরিবর্তিত হয়েছে। আপনি একটি বিশেষ টুলসেট মোডে আছেন। সম্পূর্ণ "
"API সেট পুনরুদ্ধার করতে কাজ শেষ হলে আপনাকে অবশ্যই "
"'specialized_workflow_finished' কল করতে হবে।"

#: plugin/notebook/import_dialog.py
msgid "Import Jupyter Notebook"
msgstr "Jupyter নোটবুক ইম্পোর্ট করুন"

#: plugin/notebook/import_dialog.py
msgid "Jupyter Notebook"
msgstr "Jupyter নোটবুক"

#: plugin/notebook/import_dialog.py
