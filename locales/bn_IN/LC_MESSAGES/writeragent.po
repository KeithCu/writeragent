#: plugin/framework/errors.py
#, python-brace-format
msgid "TLS/SSL Error: {0}"
msgstr "TLS/SSL ত্রুটি: {0}"

#: plugin/framework/errors.py
msgid "Invalid API Key. Please check your settings."
msgstr "অবৈধ API কী। অনুগ্রহ করে আপনার সেটিংস চেক করুন।"

#: plugin/framework/errors.py
msgid "API access Forbidden. Your key may lack permissions for this model."
msgstr ""
"API অ্যাক্সেস নিষিদ্ধ। আপনার কী-তে সম্ভবত এই মডেলের জন্য অনুমতির অভাব "
"রয়েছে।"

#: plugin/framework/errors.py
msgid "Endpoint not found (404). Check your URL and Model name."
msgstr "এন্ডপয়েন্ট পাওয়া যায়নি (404)। আপনার URL এবং মডেলের নাম চেক করুন।"

#: plugin/framework/errors.py
#, python-brace-format
msgid "Server error ({0}). The AI provider is having issues."
msgstr "সার্ভার ত্রুটি ({0})। AI প্রোভাইডারের সমস্যা হচ্ছে।"

#: plugin/framework/errors.py
#, python-brace-format
msgid "HTTP Error {0}: {1}"
msgstr "HTTP ত্রুটি {0}: {1}"

#: plugin/framework/errors.py
msgid "Request Timed Out. Try increasing 'Request Timeout' in Settings."
msgstr ""
"অনুরোধের সময় শেষ হয়েছে (Request Timed Out)। সেটিংস-এ 'Request Timeout' "
"বাড়িয়ে দেখুন।"

#: plugin/framework/errors.py
msgid ""
"Connection Refused. Is your local AI server (Ollama/LM Studio) running?"
msgstr ""
"সংযোগ প্রত্যাখ্যান করা হয়েছে। আপনার স্থানীয় AI সার্ভার (Ollama/LM Studio) "
"কি চলছে?"

#: plugin/framework/errors.py
msgid "DNS Error. Could not resolve the endpoint URL."
msgstr "DNS ত্রুটি। এন্ডপয়েন্ট URL সমাধান করা যায়নি।"

#: plugin/framework/errors.py
#, python-brace-format
msgid "Connection Error: {0}"
msgstr "সংযোগ ত্রুটি: {0}"

#: plugin/framework/errors.py
msgid "The AI provider reported an error. Try again."
msgstr "AI প্রোভাইডার একটি ত্রুটির রিপোর্ট করেছে। আবার চেষ্টা করুন।"

#: plugin/framework/errors.py
#, python-brace-format
msgid "{resource_type} not found: {identifier}"
msgstr "{resource_type} পাওয়া যায়নি: {identifier}"

#: plugin/framework/constants.py
msgid ""
"AI: I can edit or translate your document instantly with professional "
"formatting and color. Try me!"
msgstr ""
"AI: আমি পেশাদার ফরম্যাটিং এবং রঙের সাথে আপনার ডকুমেন্ট তাৎক্ষণিকভাবে "
"সম্পাদনা বা অনুবাদ করতে পারি। আমাকে ব্যবহার করে দেখুন!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you with formulas, data analysis, and colorful charts. Try "
"me!"
msgstr ""
"AI: আমি আপনাকে সূত্র, ডেটা বিশ্লেষণ এবং রঙিন চার্ট তৈরিতে সাহায্য করতে পারি।"
" আমাকে ব্যবহার করে দেখুন!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you create and edit polished, colorful shapes in Draw and "
"Impress. Try me!"
msgstr ""
"AI: আমি আপনাকে Draw এবং Impress-এ পরিশীলিত, রঙিন আকার তৈরি এবং সম্পাদনা করতে"
" সাহায্য করতে পারি। আমাকে ব্যবহার করে দেখুন!"

#: plugin/framework/constants.py
msgid ""
"AI: I can do web research to answer any question, or summarize a web page, "
"without seeing or changing your document. Let's chat."
msgstr ""
"AI: আমি আপনার ডকুমেন্ট না দেখে বা পরিবর্তন না করেই যেকোনো প্রশ্নের উত্তর "
"দিতে ওয়েব রিসার্চ করতে পারি অথবা কোনো ওয়েব পেজের সারাংশ তৈরি করতে পারি। "
"চলুন কথা বলি।"

#: plugin/framework/client/errors.py
#, python-brace-format
msgid "HTTP Error {0} from AI Provider: {1}"
msgstr "AI প্রোভাইডার থেকে HTTP ত্রুটি {0}: {1}"

#: plugin/framework/client/errors.py plugin/calc/python_function.py
#: plugin/scripting/session_manager.py
#, python-brace-format
msgid "Error: {0}"
msgstr "ত্রুটি: {0}"

#: plugin/framework/client/llm_client.py
msgid "Stream ended with finish_reason=error"
msgstr "স্ট্রিমটি finish_reason=error দিয়ে শেষ হয়েছে"

#: plugin/framework/client/llm_client.py
msgid ""
"The model is repeating the same chunk (infinite loop). Try again or use a "
"different model."
