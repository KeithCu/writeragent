#: plugin/framework/client/llm_client.py
msgid ""
"The model is repeating the same chunk (infinite loop). Try again or use a "
"different model."
msgstr ""
"মডেলটি একই অংশ বারবার পুনরাবৃত্তি করছে (ইনফিনিট লুপ)। আবার চেষ্টা করুন অথবা অন্য "
"একটি মডেল ব্যবহার করুন।"

#: plugin/framework/config.py
msgid "Chat max tokens must be >= 0"
msgstr "চ্যাট সর্বোচ্চ টোকেন অবশ্যই >= ০ হতে হবে"

#: plugin/framework/config.py
msgid "Request timeout must be > 0"
msgstr "অনুরোধের সময়সীমা অবশ্যই > ০ হতে হবে"

#: plugin/framework/config.py
msgid "Temperature must be <= 1.0"
msgstr "তাপমাত্রা অবশ্যই <= ১.০ হতে হবে"

#: plugin/framework/config.py
msgid "Please set Endpoint in Settings."
msgstr "অনুগ্রহ করে সেটিংস-এ এন্ডপয়েন্ট সেট করুন।"

#: plugin/framework/config.py
msgid "Please set Model in Settings."
msgstr "অনুগ্রহ করে সেটিংস-এ মডেল সেট করুন।"

#: plugin/framework/config.py
msgid "Please select a valid model in Settings (not a placeholder)."
msgstr "অনুগ্রহ করে সেটিংস-এ একটি বৈধ মডেল নির্বাচন করুন (প্লেসহোল্ডার নয়)।"

#: plugin/calc/python/editor_context_menu.py plugin/main.py
msgid "Edit Python in Cell..."
msgstr "সেল-এ পাইথন সম্পাদনা করুন..."

#: plugin/calc/python/editor.py
msgid ""
"Could not preserve this cell's PYTHON formula arguments (e.g. data ranges). "
"Edit the formula in Calc, or use a quoted code string like =PY(\"code\"; "
"A1:B10) or =PYTHON(...)."
msgstr ""
"এই সেলের PYTHON ফর্মুলা আর্গুমেন্ট (যেমন ডেটা রেঞ্জ) সংরক্ষণ করা সম্ভব হয়নি। Calc-এ "
"ফর্মুলাটি সম্পাদনা করুন, অথবা =PY(\"code\"; A1:B10) বা =PYTHON(...) এর মতো উদ্ধৃত "
"কোড স্ট্রিং ব্যবহার করুন।"

#: plugin/calc/python/editor.py plugin/scripting/editor_ui_strings.py
msgid "Saved without =PY()."
msgstr "=PY() ছাড়া সংরক্ষিত।"

#: plugin/calc/python/editor.py
msgid "Python cell editor"
msgstr "পাইথন সেল এডিটর"

#: plugin/calc/python/editor.py plugin/scripting/editor_ui_strings.py
msgid "Save without =PY()"
msgstr "=PY() ছাড়া সংরক্ষণ করুন"

#: plugin/calc/python/editor.py plugin/scripting/editor_ui_strings.py
#: plugin/scripting/python_runner.py plugin/xdl_strings.py
msgid "Save"
msgstr "সংরক্ষণ করুন"

#: plugin/calc/python/editor.py
msgid "The Python editor failed unexpectedly."
msgstr "পাইথন এডিটরটি অপ্রত্যাশিতভাবে ব্যর্থ হয়েছে।"

#: plugin/calc/python/editor.py
msgid "Select a cell in a Calc spreadsheet to edit Python."
msgstr "পাইথন সম্পাদনা করতে Calc স্প্রেডশিটে একটি সেল নির্বাচন করুন।"

#: plugin/calc/python/editor.py
msgid ""
"This PYTHON formula uses a form the editor cannot safely rewrite (e.g. code "
"in another cell). Edit it in the formula bar, or use =PY(\"code\"; range) "
"(or =PYTHON(...)) with quoted code."
msgstr ""
"এই PYTHON ফর্মুলাটি এমন একটি ফরম্যাট ব্যবহার করে যা এডিটর নিরাপদে পুনরায় লিখতে "
"পারে না (যেমন অন্য সেলের কোড)। এটি ফর্মুলা বারে সম্পাদনা করুন, অথবা উদ্ধৃত কোড সহ "
"=PY(\"code\"; range) (বা =PYTHON(...)) ব্যবহার করুন।"

#: plugin/calc/python/editor.py
msgid ""
"Edit Python in Cell requires the Monaco editor, which is disabled by "
"\"scripting.force_internal_script_editor\" in writeragent.json.\n"
"\n"
"Set it to false and restart LibreOffice to use this command, or edit PYTHON "
"formulas in the Calc formula bar."
msgstr ""
"Edit Python in Cell-এর জন্য Monaco এডিটর প্রয়োজন, যা writeragent.json-এ "
"\"scripting.force_internal_script_editor\" দ্বারা নিষ্ক্রিয় করা হয়েছে।\n"
"\n"
"এই কমান্ডটি ব্যবহার করতে এটিকে false-এ সেট করুন এবং LibreOffice রিস্টার্ট করুন, "
"অথবা Calc ফর্মুলা বারে PYTHON ফর্মুলা এডিট করুন।"

#: plugin/calc/python/editor.py
msgid "No Python interpreter available for the editor."
msgstr "এডিটরের জন্য কোনো পাইথন ইন্টারপ্রেটার উপলব্ধ নেই।"

#: plugin/calc/python/editor.py
#, python-format
msgid ""
"Cannot import webview (pywebview) or rocher with the Python from Settings → "
"Python:\n"
"%(exe)s\n"
"\n"
"In that venv run: uv pip install pywebview rocher\n"
"(import name is webview, package name is pywebview)."
msgstr ""
"Settings → Python-এ থাকা Python ব্যবহার করে webview (pywebview) অথবা rocher "
"ইম্পোর্ট করা যাচ্ছে না:\n"
