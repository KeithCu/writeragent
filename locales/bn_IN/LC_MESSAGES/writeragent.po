#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"ডকুমেন্ট গবেষণার জন্য সাব-এজেন্ট ডেলিগেশন (USE_SUB_AGENT) প্রয়োজন। "
"কনফিগারেশনে সাব-এজেন্ট সক্রিয় করুন।"

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"টুল কল '{0}'-এ পরিবর্তিত হয়েছে। আপনি একটি বিশেষ টুলসেট মোডে আছেন। সম্পূর্ণ "
"API সেট পুনরুদ্ধার করতে কাজ শেষ হলে আপনাকে অবশ্যই "
"'specialized_workflow_finished' কল করতে হবে।"

#: plugin/notebook/notebook_runner.py
msgid "Cell execution failed."
msgstr "সেল কার্যকর করতে ব্যর্থ হয়েছে।"

#: plugin/notebook/notebook_runner.py
msgid "Notebook run is only supported in LibreOffice Writer."
msgstr "নোটবুক রান শুধুমাত্র LibreOffice Writer-এ সমর্থিত।"

#: plugin/notebook/notebook_runner.py
msgid ""
"This document has no imported notebook. Use Tools → Import Jupyter Notebook…"
" first."
msgstr ""
"এই নথিতে কোনো আমদানিকৃত নোটবুক নেই। প্রথমে Tools → Import Jupyter Notebook… "
"ব্যবহার করুন।"

#: plugin/notebook/notebook_runner.py
msgid "Could not find notebook cell for this control."
msgstr "এই নিয়ন্ত্রণের জন্য নোটবুক সেল খুঁজে পাওয়া যায়নি।"

#: plugin/notebook/notebook_runner.py plugin/notebook/import_dialog.py
msgid "Open a Writer document first."
msgstr "প্রথমে একটি Writer ডকুমেন্ট খুলুন।"

#: plugin/notebook/import_dialog.py
msgid "Import Jupyter Notebook"
msgstr "Jupyter নোটবুক ইম্পোর্ট করুন"

#: plugin/notebook/import_dialog.py
msgid "Jupyter Notebook"
msgstr "Jupyter নোটবুক"

#: plugin/notebook/import_dialog.py
msgid "All files"
msgstr "সমস্ত ফাইল"

#: plugin/notebook/import_dialog.py
msgid "Import Notebook is only supported in LibreOffice Writer."
msgstr "নোটবুক ইম্পোর্ট শুধুমাত্র LibreOffice Writer-এ সমর্থিত।"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid "Failed to import notebook: {error}"
msgstr "নোটবুক ইম্পোর্ট করতে ব্যর্থ: {error}"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid ""
"Imported notebook.\n"
"Cells: {cells} (code: {code}, markdown: {markdown})\n"
"Code input fields in document: {shapes}\n"
"Output images: {images}"
msgstr ""
"নোটবুক ইম্পোর্ট করা হয়েছে।\n"
"সেল: {cells} (কোড: {code}, মার্কডাউন: {markdown})\n"
"ডকুমেন্টে কোড ইনপুট ফিল্ড: {shapes}\n"
"আউটপুট ইমেজ: {images}"

#: plugin/notebook/writer_importer.py
msgid "Run code cell"
msgstr "কোড সেল চালান"

#: plugin/contrib/aihordeclient/__init__.py plugin/chatbot/panel.py
msgid "Starting..."
msgstr "শুরু হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Updating model requirements..."
msgstr "মডেলের প্রয়োজনীয়তা আপডেট করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Updating Models..."
msgstr "মডেল আপডেট করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Register at "
msgstr "এখানে নিবন্ধন করুন "

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "You have {} kudos"
msgstr "আপনার {} কুডো (kudos) আছে"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "«{}» is not a valid API KEY, double check it or create a new one"
msgstr ""
"«{}» একটি বৈধ API KEY নয়, এটি পুনরায় পরীক্ষা করুন অথবা একটি নতুন তৈরি করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"At this moment we can not process your request, please try again later.  If "
"this is happening for a long period of time, please let us know via Discord"
msgstr ""
"এই মুহূর্তে আমরা আপনার অনুরোধটি প্রক্রিয়া করতে পারছি না, অনুগ্রহ করে পরে "
"আবার চেষ্টা করুন। যদি এটি দীর্ঘ সময় ধরে ঘটতে থাকে, তবে অনুগ্রহ করে ডিসকর্ড "
"(Discord)-এর মাধ্যমে আমাদের জানান"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Problem requesting kudos"
msgstr "কুডো (kudos) অনুরোধ করতে সমস্যা হয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"The Horde is in maintenance mode, please try again later, if you have tried "
"and the service does not respond for hours, please contact via Discord"
msgstr ""
"হোর্ড (Horde) রক্ষণাবেক্ষণ মোডে আছে, অনুগ্রহ করে পরে আবার চেষ্টা করুন, যদি "
"আপনি চেষ্টা করে থাকেন এবং পরিষেবাটি ঘণ্টার পর ঘণ্টা সাড়া না দেয়, তবে "
"অনুগ্রহ করে ডিসকর্ড (Discord)-এর মাধ্যমে যোগাযোগ করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You have made too many requests, please wait for them to finish, and try "
"again later"
msgstr ""
"আপনি খুব বেশি অনুরোধ করেছেন, অনুগ্রহ করে সেগুলোর সমাপ্তির জন্য অপেক্ষা করুন "
"এবং পরে আবার চেষ্টা করুন"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Seems that «{}» has problems, double check it, create a new one or join "
"Discord to ask for help"
msgstr ""
"«{}»-এ সমস্যা দেখা দিয়েছে বলে মনে হচ্ছে, এটি পুনরায় পরীক্ষা করুন, নতুন "
"একটি তৈরি করুন অথবা সাহায্যের জন্য ডিসকর্ড (Discord)-এ যোগ দিন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "We hit an error, still: "
msgstr "আমরা একটি ত্রুটির সম্মুখীন হয়েছি, তবুও: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "No longer valid, please try again.  Your request took too long"
msgstr ""
"আর বৈধ নয়, অনুগ্রহ করে আবার চেষ্টা করুন। আপনার অনুরোধটি সম্পন্ন হতে অনেক "
"সময় নিয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Contacting the Horde..."
msgstr "হোর্ড (Horde)-এর সাথে যোগাযোগ করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Horde Contacted"
msgstr "হোর্ড (Horde)-এর সাথে যোগাযোগ সফল হয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"When trying to ask for the image, the Horde was too slow, try again later"
msgstr ""
"ছবিটির জন্য অনুরোধ করার সময়, হোর্ড (Horde) খুব ধীর ছিল, পরে আবার চেষ্টা "
"করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "to learn to earn kudos. Detail:"
msgstr "কুডোস (kudos) অর্জন করতে শিখুন। বিস্তারিত:"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Service failed: "
msgstr "পরিষেবা ব্যর্থ হয়েছে: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading generated image..."
msgstr "তৈরিকৃত ছবিটি ডাউনলোড করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "You are first in the queue"
msgstr "আপনি সারিতে প্রথম স্থানে আছেন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Queue position: "
msgstr "সারির অবস্থান: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "Generating..."
msgstr "তৈরি হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Get a free API Key at "
msgstr "একটি বিনামূল্যে API কী পান এখানে "

#: plugin/contrib/aihordeclient/__init__.py
msgid "."
msgstr "|"

#: plugin/contrib/aihordeclient/__init__.py
msgid "This model takes more time than your current configuration."
msgstr "এই মডেলটি আপনার বর্তমান কনফিগারেশনের চেয়ে বেশি সময় নেয়।"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Please try another model. {0} would take more time than you configured."
msgstr ""
"অনুগ্রহ করে অন্য একটি মডেল ব্যবহার করে দেখুন। {0} আপনার কনফিগার করা সময়ের "
"চেয়ে বেশি সময় নেবে।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Please try again later."
msgstr "অনুগ্রহ করে পরে আবার চেষ্টা করুন।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "There are no workers available with these settings."
msgstr "এই সেটিংসের সাথে কোনো কর্মী উপলব্ধ নেই।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Probably your image will take one additional minute."
msgstr "সম্ভবত আপনার ছবিটির জন্য অতিরিক্ত এক মিনিট সময় লাগবে।"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "Probably your image will take {} additional minutes."
msgstr "সম্ভবত আপনার ছবিটির জন্য {} মিনিট অতিরিক্ত সময় লাগবে।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Fetching images..."
msgstr "ছবি আনা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid " is censored, try changing the prompt wording"
msgstr " সেন্সর করা হয়েছে, প্রম্পটের শব্দ পরিবর্তন করার চেষ্টা করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading result..."
msgstr "ফলাফল ডাউনলোড করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading image"
msgstr "ছবি ডাউনলোড করা হচ্ছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You may need to reduce your settings or choose another model, or you may "
