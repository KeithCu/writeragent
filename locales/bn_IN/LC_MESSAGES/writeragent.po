msgid "Generating..."
msgstr "তৈরি হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Get a free API Key at "
msgstr "একটি বিনামূল্যে API কী পান এখানে "

#: plugin/contrib/aihordeclient/__init__.py
msgid "."
msgstr "|"

#: plugin/contrib/aihordeclient/__init__.py
msgid "This model takes more time than your current configuration."
msgstr "এই মডেলটি আপনার বর্তমান কনফিগারেশনের চেয়ে বেশি সময় নেয়।"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Please try another model. {0} would take more time than you configured."
msgstr ""
"অনুগ্রহ করে অন্য একটি মডেল ব্যবহার করে দেখুন। {0} আপনার কনফিগার করা সময়ের "
"চেয়ে বেশি সময় নেবে।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Please try again later."
msgstr "অনুগ্রহ করে পরে আবার চেষ্টা করুন।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "There are no workers available with these settings."
msgstr "এই সেটিংসের সাথে কোনো কর্মী উপলব্ধ নেই।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Probably your image will take one additional minute."
msgstr "সম্ভবত আপনার ছবিটির জন্য অতিরিক্ত এক মিনিট সময় লাগবে।"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "Probably your image will take {} additional minutes."
msgstr "সম্ভবত আপনার ছবিটির জন্য {} মিনিট অতিরিক্ত সময় লাগবে।"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Fetching images..."
msgstr "ছবি আনা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
