msgstr "প্রথমে একটি Writer ডকুমেন্ট খুলুন।"

#: plugin/notebook/import_dialog.py
msgid "Import Notebook is only supported in LibreOffice Writer."
msgstr "নোটবুক ইম্পোর্ট শুধুমাত্র LibreOffice Writer-এ সমর্থিত।"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid "Failed to import notebook: {error}"
msgstr "নোটবুক ইম্পোর্ট করতে ব্যর্থ: {error}"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid ""
"Imported notebook.\n"
"Cells: {cells} (code: {code}, markdown: {markdown})\n"
"Code input fields in document: {shapes}\n"
"Output images: {images}"
msgstr ""
"নোটবুক ইম্পোর্ট করা হয়েছে।\n"
"সেল: {cells} (কোড: {code}, মার্কডাউন: {markdown})\n"
"ডকুমেন্টে কোড ইনপুট ফিল্ড: {shapes}\n"
"আউটপুট ইমেজ: {images}"

