#: plugin/contrib/aihordeclient/__init__.py
msgid "Updating Models..."
msgstr "মডেল আপডেট করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Register at "
msgstr "এখানে নিবন্ধন করুন "

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "You have {} kudos"
msgstr "আপনার {} কুডো (kudos) আছে"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "«{}» is not a valid API KEY, double check it or create a new one"
msgstr ""
"«{}» একটি বৈধ API KEY নয়, এটি পুনরায় পরীক্ষা করুন অথবা একটি নতুন তৈরি করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"At this moment we can not process your request, please try again later.  If "
"this is happening for a long period of time, please let us know via Discord"
msgstr ""
"এই মুহূর্তে আমরা আপনার অনুরোধটি প্রক্রিয়া করতে পারছি না, অনুগ্রহ করে পরে "
"আবার চেষ্টা করুন। যদি এটি দীর্ঘ সময় ধরে ঘটতে থাকে, তবে অনুগ্রহ করে ডিসকর্ড "
"(Discord)-এর মাধ্যমে আমাদের জানান"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Problem requesting kudos"
msgstr "কুডো (kudos) অনুরোধ করতে সমস্যা হয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"The Horde is in maintenance mode, please try again later, if you have tried "
"and the service does not respond for hours, please contact via Discord"
msgstr ""
"হোর্ড (Horde) রক্ষণাবেক্ষণ মোডে আছে, অনুগ্রহ করে পরে আবার চেষ্টা করুন, যদি "
"আপনি চেষ্টা করে থাকেন এবং পরিষেবাটি ঘণ্টার পর ঘণ্টা সাড়া না দেয়, তবে "
"অনুগ্রহ করে ডিসকর্ড (Discord)-এর মাধ্যমে যোগাযোগ করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You have made too many requests, please wait for them to finish, and try "
"again later"
msgstr ""
"আপনি খুব বেশি অনুরোধ করেছেন, অনুগ্রহ করে সেগুলোর সমাপ্তির জন্য অপেক্ষা করুন "
"এবং পরে আবার চেষ্টা করুন"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Seems that «{}» has problems, double check it, create a new one or join "
"Discord to ask for help"
msgstr ""
"«{}»-এ সমস্যা দেখা দিয়েছে বলে মনে হচ্ছে, এটি পুনরায় পরীক্ষা করুন, নতুন "
"একটি তৈরি করুন অথবা সাহায্যের জন্য ডিসকর্ড (Discord)-এ যোগ দিন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "We hit an error, still: "
msgstr "আমরা একটি ত্রুটির সম্মুখীন হয়েছি, তবুও: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "No longer valid, please try again.  Your request took too long"
msgstr ""
"আর বৈধ নয়, অনুগ্রহ করে আবার চেষ্টা করুন। আপনার অনুরোধটি সম্পন্ন হতে অনেক "
"সময় নিয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Contacting the Horde..."
msgstr "হোর্ড (Horde)-এর সাথে যোগাযোগ করা হচ্ছে..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Horde Contacted"
msgstr "হোর্ড (Horde)-এর সাথে যোগাযোগ সফল হয়েছে"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"When trying to ask for the image, the Horde was too slow, try again later"
msgstr ""
"ছবিটির জন্য অনুরোধ করার সময়, হোর্ড (Horde) খুব ধীর ছিল, পরে আবার চেষ্টা "
"করুন"

#: plugin/contrib/aihordeclient/__init__.py
msgid "to learn to earn kudos. Detail:"
msgstr "কুডোস (kudos) অর্জন করতে শিখুন। বিস্তারিত:"

