#: plugin/doc/specialized_base.py
msgid ""
"Local OCR requires Settings → Python venv with Docling or PaddleOCR "
"(Settings → Python → Test for install hints)."
msgstr ""
"স্থানীয় OCR-এর জন্য Settings → Python venv (Docling বা PaddleOCR সহ) প্রয়োজন "
"(Settings → Python → Test-এ ইনস্টল সংক্রান্ত নির্দেশাবলী দেখুন)।"

#: plugin/doc/specialized_base.py
msgid "Running local OCR on selected image..."
msgstr "নির্বাচিত ছবিতে স্থানীয় OCR চালানো হচ্ছে..."

#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT). "
"Enable this in configuration."
msgstr ""
"ডকুমেন্ট গবেষণার জন্য বিশেষ টাস্ক ডেলিগেশন (USE_SUB_AGENT) প্রয়োজন। কনফিগারেশনে "
"এটি সক্রিয় করুন।"

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must "
"call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"টুল কল '{0}'-এ পরিবর্তিত হয়েছে। আপনি একটি বিশেষ টুলসেট মোডে আছেন। সম্পূর্ণ API সেট "
"পুনরুদ্ধার করতে কাজ শেষ হলে আপনাকে অবশ্যই 'specialized_workflow_finished' কল "
"করতে হবে।"

#: plugin/notebook/notebook_runner.py
msgid "Cell execution failed."
msgstr "সেল কার্যকর করতে ব্যর্থ হয়েছে।"

#: plugin/notebook/notebook_runner.py
msgid "Notebook run is only supported in LibreOffice Writer."
msgstr "নোটবুক রান শুধুমাত্র LibreOffice Writer-এ সমর্থিত।"

#: plugin/notebook/notebook_runner.py
msgid ""
"This document has no imported notebook. Use Tools → Import Jupyter Notebook… "
"first."
msgstr ""
"এই নথিতে কোনো আমদানিকৃত নোটবুক নেই। প্রথমে Tools → Import Jupyter Notebook… "
"ব্যবহার করুন।"

#: plugin/notebook/notebook_runner.py
msgid "Could not find notebook cell for this control."
msgstr "এই নিয়ন্ত্রণের জন্য নোটবুক সেল খুঁজে পাওয়া যায়নি।"

#: plugin/notebook/notebook_runner.py plugin/notebook/import_dialog.py
msgid "Open a Writer document first."
msgstr "প্রথমে একটি Writer ডকুমেন্ট খুলুন।"

#: plugin/notebook/import_dialog.py
msgid "Import Jupyter Notebook"
msgstr "Jupyter নোটবুক ইম্পোর্ট করুন"

#: plugin/notebook/import_dialog.py
msgid "Jupyter Notebook"
msgstr "Jupyter নোটবুক"

#: plugin/notebook/import_dialog.py
msgid "All files"
msgstr "সমস্ত ফাইল"

#: plugin/notebook/import_dialog.py
msgid "Import Notebook is only supported in LibreOffice Writer."
msgstr "নোটবুক ইম্পোর্ট শুধুমাত্র LibreOffice Writer-এ সমর্থিত।"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid "Failed to import notebook: {error}"
msgstr "নোটবুক ইম্পোর্ট করতে ব্যর্থ: {error}"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid ""
"Imported notebook.\n"
"Cells: {cells} (code: {code}, markdown: {markdown})\n"
"Code input fields in document: {shapes}\n"
"Output images: {images}"
msgstr ""
"নোটবুক ইম্পোর্ট করা হয়েছে।\n"
"সেল: {cells} (কোড: {code}, মার্কডাউন: {markdown})\n"
"ডকুমেন্টে কোড ইনপুট ফিল্ড: {shapes}\n"
"আউটপুট ইমেজ: {images}"

