msgstr "MCP-Server aktivieren"

msgid ""
"Localhost only, no auth. Clients use http://localhost:<port>/mcp (streamable"
" HTTP)."
msgstr ""
"Nur Localhost, keine Authentifizierung. Clients verwenden "
"http://localhost:<port>/mcp (streambares HTTP)."

msgid "MCP Port"
msgstr "MCP-Port"

msgid "Allow CORS from local origins"
msgstr "CORS von lokalen Ursprüngen erlauben"

msgid ""
"Automatic for .local, .lan, .home.arpa, .internal, .intern, and LAN IPs in "
"the browser Origin. For other hosts, add mcp.cors_allowed_origins in "
"writeragent.json."
msgstr ""
"Automatisch für .local, .lan, .home.arpa, .internal, .intern und LAN-IPs im "
"Browser-Origin. Für andere Hosts fügen Sie mcp.cors_allowed_origins in "
"writeragent.json hinzu."

