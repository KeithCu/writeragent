msgstr ""
"Opt-in. Lädt bei der ersten Verwendung zusätzliche VLM-Modelle herunter; "
"langsamer."

msgid "Code block enrichment"
msgstr "Codeblock-Anreicherung"

msgid "Specialized OCR for code/terminal screenshots."
msgstr "Spezialisierte OCR für Code-/Terminal-Screenshots."

msgid "Docling document timeout (s)"
msgstr "Docling-Dokument-Zeitlimit (s)"

