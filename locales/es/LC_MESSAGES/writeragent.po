#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Las lecturas de investigación de documentos requieren una delegación de "
"tareas especializada (USE_SUB_AGENT). Habilítelo en la configuración."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "Sesión de lluvia de ideas iniciada."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "Sesión de lluvia de ideas completada."

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"La lluvia de ideas requiere la conexión de la sesión en la barra lateral "
"(start_brainstorming_session_callback)."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Llamada de herramienta cambiada a '{0}'. Estás en un modo de conjunto de "
"herramientas especializado. Debes llamar a 'specialized_workflow_finished' "
"cuando termines para restaurar el conjunto completo de APIs."

