#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"Las lecturas de investigación de documentos requieren delegación de "
"subagentes (USE_SUB_AGENT). Habilite los subagentes en la configuración."

