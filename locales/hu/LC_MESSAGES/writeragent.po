#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"A dokumentumkutatási olvasások alügynöki delegálást igényelnek "
"(USE_SUB_AGENT). Engedélyezze az alügynököket a konfigurációban."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Az eszközhívás átváltva erre: „{0}”. Speciális eszközkészlet módban van. A "
"teljes API-készlet visszaállításához a munka végeztével meg kell hívnia a "
"„specialized_workflow_finished” parancsot."

