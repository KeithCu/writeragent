#: plugin/calc/python/editor.py
msgid ""
"Could not preserve this cell's PYTHON formula arguments (e.g. data ranges). "
"Edit the formula in Calc, or use a quoted code string like =PY(\"code\"; "
"A1:B10) or =PYTHON(...)."
msgstr ""
"Tämän solun PYTHON-kaavan argumentteja (esim. tietoalueita) ei voitu "
"säilyttää. Muokkaa kaavaa Calcissa tai käytä lainattua koodimerkkijonoa, "
"kuten =PY(\"koodi\"; A1:B10) tai =PYTHON(...)."

#: plugin/calc/python/editor.py plugin/scripting/editor_ui_strings.py
msgid "Saved without =PY()."
msgstr "Tallennettu ilman =PY()-funktiota."

