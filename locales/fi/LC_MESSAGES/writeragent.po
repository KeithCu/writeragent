#: plugin/doc/specialized_base.py
msgid ""
"Local OCR requires Settings → Python venv with Docling or PaddleOCR "
"(Settings → Python → Test for install hints)."
msgstr ""
"Paikallinen tekstintunnistus (OCR) vaatii asetukset: Asetukset → Python-"
"virtuaaliympäristö, jossa on Docling tai PaddleOCR (Asetukset → Python → "
"Testaa asennusvihjeitä varten)."

#: plugin/doc/specialized_base.py
msgid "Running local OCR on selected image..."
msgstr "Suoritetaan paikallista tekstintunnistusta valitulle kuvalle..."

#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT). "
"Enable this in configuration."
msgstr ""
"Asiakirjatutkimus vaatii erikoistuneen tehtävän delegoinnin (USE_SUB_AGENT). "
"Ota tämä käyttöön asetuksista."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must "
"call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Työkalukutsu vaihdettu tilaan '{0}'. Olet erikoistyökalutilassa. Sinun on "
"kutsuttava 'specialized_workflow_finished', kun olet valmis, jotta voit "
"palauttaa täyden API-joukon."

