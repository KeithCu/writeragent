msgstr ""
"Pieprasīt apstiprinājumu pirms tīmekļa meklēšanas vaicājuma nosūtīšanas"

msgid "Web Cache Max Size (MB)"
msgstr "Tīmekļa kešatmiņas maksimālais izmērs (MB)"

