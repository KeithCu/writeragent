msgstr ""
"html = Docling HTML imports (noklusējums). structured = bbox kolonnu "
"izkārtojums programmā Writer; vietējās Calc šūnas extract_structure tabulām."

msgid "Standard HTML"
msgstr "Standarta HTML"

