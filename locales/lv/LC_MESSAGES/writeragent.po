msgstr "Strukturēts (izkārtojums / šūnu režģis)"

msgid "Layout model"
msgstr "Izkārtojuma modelis"

msgid "Heron (default)"
msgstr "Heron (noklusējuma)"

msgid "Egret large (slower"
msgstr "Egret large (lēnāks"

msgid "Extract formulas (LaTeX)"
msgstr "Izvilkt formulas (LaTeX)"

