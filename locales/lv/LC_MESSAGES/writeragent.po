#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"Dokumentu izpētes lasījumiem ir nepieciešama apakšaģenta deleģēšana "
"(USE_SUB_AGENT). Iespējojiet apakšaģentus konfigurācijā."

#: plugin/doc/specialized_base.py
#, python-brace-format
