msgstr ""
"Neobligāta mape docling-tools modeļu lejupielādei (izmantošanai bezsaistē)."

msgid "OCR confidence threshold"
msgstr "OCR ticamības slieksnis"

msgid "RapidOCR minimum text score. Raise to reduce garbage text."
msgstr ""
"RapidOCR minimālais teksta rādītājs. Palieliniet, lai samazinātu "
"nekvalitatīvu tekstu."

msgid "OCR entire image"
msgstr "OCR visam attēlam"

