#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"दस्तावेज़ अनुसंधान रीड्स के लिए विशेष कार्य प्रतिनिधिमंडल (USE_SUB_AGENT) की"
" आवश्यकता होती है। इसे कॉन्फ़िगरेशन में सक्षम करें।"

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "ब्रेनस्टॉर्मिंग सत्र शुरू हुआ।"

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "ब्रेनस्टॉर्मिंग सत्र पूरा हुआ।"

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"ब्रेनस्टॉर्मिंग के लिए साइडबार सत्र वायरिंग "
"(start_brainstorming_session_callback) की आवश्यकता है।"

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"टूल कॉल '{0}' पर स्विच हो गया है। आप एक विशेष टूलसेट मोड में हैं। पूर्ण API "
"सेट को पुनर्स्थापित करने के लिए आपको कार्य पूरा होने पर "
"'specialized_workflow_finished' कॉल करना होगा।"

#: plugin/notebook/notebook_runner.py
msgid "Cell execution failed."
msgstr "सेल निष्पादन विफल रहा।"

#: plugin/notebook/notebook_runner.py
msgid "Notebook run is only supported in LibreOffice Writer."
msgstr "नोटबुक रन केवल LibreOffice Writer में समर्थित है।"

#: plugin/notebook/notebook_runner.py
msgid ""
"This document has no imported notebook. Use Tools → Import Jupyter Notebook…"
" first."
msgstr ""
"इस दस्तावेज़ में कोई आयातित नोटबुक नहीं है। पहले उपकरण → Jupyter नोटबुक आयात"
" करें… का उपयोग करें।"

#: plugin/notebook/notebook_runner.py
msgid "Could not find notebook cell for this control."
msgstr "इस नियंत्रण के लिए नोटबुक सेल नहीं मिल सका।"

#: plugin/notebook/notebook_runner.py plugin/notebook/import_dialog.py
msgid "Open a Writer document first."
msgstr "पहले एक Writer दस्तावेज़ खोलें।"

#: plugin/notebook/import_dialog.py
msgid "Import Jupyter Notebook"
msgstr "Jupyter नोटबुक आयात करें"

#: plugin/notebook/import_dialog.py
msgid "Jupyter Notebook"
msgstr "Jupyter नोटबुक"

#: plugin/notebook/import_dialog.py
msgid "All files"
msgstr "सभी फ़ाइलें"

#: plugin/notebook/import_dialog.py
msgid "Import Notebook is only supported in LibreOffice Writer."
msgstr "नोटबुक आयात केवल LibreOffice Writer में समर्थित है।"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid "Failed to import notebook: {error}"
msgstr "नोटबुक आयात करने में विफल: {error}"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid ""
"Imported notebook.\n"
"Cells: {cells} (code: {code}, markdown: {markdown})\n"
"Code input fields in document: {shapes}\n"
"Output images: {images}"
msgstr ""
"नोटबुक आयातित।\n"
"सेल्स: {cells} (कोड: {code}, मार्कडाउन: {markdown})\n"
"दस्तावेज़ में कोड इनपुट फ़ील्ड: {shapes}\n"
"आउटपुट चित्र: {images}"

