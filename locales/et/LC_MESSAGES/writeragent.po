#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT). "
"Enable this in configuration."
msgstr ""
"Dokumendi uurimine nõuab spetsiaalset ülesannete delegeerimist "
"(USE_SUB_AGENT). Lubage see seadistustes."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "Ajurünnak on alanud."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "Ajurünnak on lõpetatud."

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"Ajurünnak nõuab külgpaneeli seansi ühendamist "
"(start_brainstorming_session_callback)."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must "
"call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Tööriista väljakutse lülitus režiimile '{0}'. Olete spetsiaalses "
"tööriistakomplekti režiimis. Täieliku API-de komplekti taastamiseks peate "
"töö lõpetamisel kutsuma funktsiooni 'specialized_workflow_finished'."

