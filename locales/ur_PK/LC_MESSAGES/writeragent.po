#, python-brace-format
msgid "TLS/SSL Error: {0}"
msgstr "TLS/SSL خرابی: {0}"

#: plugin/framework/errors.py
msgid "Invalid API Key. Please check your settings."
msgstr "غلط API کلید۔ براہ کرم اپنی ترتیبات چیک کریں۔"

#: plugin/framework/errors.py
msgid "API access Forbidden. Your key may lack permissions for this model."
msgstr ""
"API تک رسائی ممنوع ہے۔ آپ کی کلید میں شاید اس ماڈل کے لیے اجازتیں نہ ہوں۔"

#: plugin/framework/errors.py
msgid "Endpoint not found (404). Check your URL and Model name."
msgstr "اینڈ پوائنٹ نہیں ملا (404)۔ اپنا URL اور ماڈل کا نام چیک کریں۔"

#: plugin/framework/errors.py
#, python-brace-format
msgid "Server error ({0}). The AI provider is having issues."
msgstr "سرور کی خرابی ({0})۔ AI فراہم کنندہ کو مسائل کا سامنا ہے۔"

#: plugin/framework/errors.py
#, python-brace-format
msgid "HTTP Error {0}: {1}"
msgstr "HTTP خرابی {0}: {1}"

#: plugin/framework/errors.py
msgid "Request Timed Out. Try increasing 'Request Timeout' in Settings."
msgstr ""
"درخواست کا وقت ختم ہو گیا۔ ترتیبات میں 'Request Timeout' کو بڑھانے کی کوشش "
"کریں۔"

#: plugin/framework/errors.py
msgid ""
"Connection Refused. Is your local AI server (Ollama/LM Studio) running?"
msgstr ""
"کنکشن مسترد کر دیا گیا۔ کیا آپ کا مقامی AI سرور (Ollama/LM Studio) چل رہا "
"ہے؟"

#: plugin/framework/errors.py
msgid "DNS Error. Could not resolve the endpoint URL."
msgstr "DNS کی خرابی۔ اینڈ پوائنٹ URL کو حل نہیں کیا جا سکا۔"

#: plugin/framework/errors.py
#, python-brace-format
msgid "Connection Error: {0}"
msgstr "کنکشن کی خرابی: {0}"

#: plugin/framework/errors.py
msgid "The AI provider reported an error. Try again."
msgstr "AI فراہم کنندہ نے ایک خرابی کی اطلاع دی ہے۔ دوبارہ کوشش کریں۔"

#: plugin/framework/errors.py
#, python-brace-format
msgid "{resource_type} not found: {identifier}"
msgstr "{resource_type} نہیں ملا: {identifier}"

#: plugin/framework/constants.py
msgid ""
"AI: I can edit or translate your document instantly with professional "
"formatting and color. Try me!"
msgstr ""
"AI: میں آپ کی دستاویز کو پیشہ ورانہ فارمیٹنگ اور رنگ کے ساتھ فوری طور پر "
"ایڈٹ یا ترجمہ کر سکتا ہوں۔ مجھے آزمائیں!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you with formulas, data analysis, and colorful charts. Try "
"me!"
msgstr ""
"AI: میں فارمولوں، ڈیٹا کے تجزیے، اور رنگین چارٹس کے ساتھ آپ کی مدد کر سکتا "
"ہوں۔ مجھے آزمائیں!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you create and edit polished, colorful shapes in Draw and "
"Impress. Try me!"
msgstr ""
"AI: میں Draw اور Impress میں شاندار، رنگین اشکال بنانے اور ایڈٹ کرنے میں آپ "
"کی مدد کر سکتا ہوں۔ مجھے آزمائیں!"

#: plugin/framework/constants.py
msgid ""
"AI: I can do web research to answer any question, or summarize a web page, "
"without seeing or changing your document. Let's chat."
msgstr ""
"AI: میں کسی بھی سوال کا جواب دینے کے لیے ویب ریسرچ کر سکتا ہوں، یا آپ کی "
"دستاویز کو دیکھے یا تبدیل کیے بغیر کسی ویب صفحہ کا خلاصہ کر سکتا ہوں۔ آئیے "
"بات کرتے ہیں۔"

#: plugin/framework/constants.py
msgid ""
"AI: Let's explore and design your idea together. I'll ask questions, suggest"
" approaches, and help you build an approved spec in your document when "
"you're ready."
msgstr ""
"AI: آئیے آپ کے آئیڈیا کو ایک ساتھ تلاش کریں اور ڈیزائن کریں۔ میں سوالات "
"پوچھوں گا، طریقے تجویز کروں گا، اور جب آپ تیار ہوں گے تو آپ کی دستاویز میں "
"منظور شدہ تفصیلات بنانے میں آپ کی مدد کروں گا۔"

#: plugin/framework/constants.py
msgid ""
"AI: Let's draft your document section-by-section. I'll help you create a "
"writing plan outline, and then implement it incrementally with your "
"approval."
msgstr ""
"AI: آئیے آپ کی دستاویز کو سیکشن بہ سیکشن تیار کریں۔ میں آپ کی تحریری منصوبہ "
"بندی کی خاکہ سازی میں مدد کروں گا، اور پھر آپ کی منظوری کے ساتھ اسے مرحلہ "
"وار مکمل کروں گا۔"

#: plugin/framework/client/errors.py
#, python-brace-format
