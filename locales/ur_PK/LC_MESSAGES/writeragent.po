msgid "Service failed: "
msgstr "سروس ناکام ہو گئی: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading generated image..."
msgstr "تخلیق شدہ تصویر ڈاؤن لوڈ کی جا رہی ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "You are first in the queue"
msgstr "آپ قطار میں پہلے نمبر پر ہیں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Queue position: "
msgstr "قطار میں پوزیشن: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "Generating..."
msgstr "تخلیق ہو رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Get a free API Key at "
msgstr "مفت API کلید یہاں سے حاصل کریں "

#: plugin/contrib/aihordeclient/__init__.py
msgid "."
msgstr "۔"

#: plugin/contrib/aihordeclient/__init__.py
msgid "This model takes more time than your current configuration."
msgstr "یہ ماڈل آپ کی موجودہ ترتیب سے زیادہ وقت لیتا ہے۔"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Please try another model. {0} would take more time than you configured."
msgstr ""
"براہ کرم کوئی دوسرا ماڈل آزمائیں۔ {0} آپ کی ترتیب کردہ وقت سے زیادہ لے گا۔"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Please try again later."
msgstr "براہ کرم بعد میں دوبارہ کوشش کریں۔"

#: plugin/contrib/aihordeclient/__init__.py
msgid "There are no workers available with these settings."
msgstr "ان ترتیبات کے ساتھ کوئی ورکر دستیاب نہیں ہے۔"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Probably your image will take one additional minute."
msgstr "غالباً آپ کی تصویر ایک اضافی منٹ لے گی۔"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "Probably your image will take {} additional minutes."
msgstr "غالباً آپ کی تصویر {} اضافی منٹ لے گی۔"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Fetching images..."
msgstr "تصاویر حاصل کی جا رہی ہیں..."

#: plugin/contrib/aihordeclient/__init__.py
msgid " is censored, try changing the prompt wording"
msgstr " سنسر شدہ ہے، پرامپٹ کے الفاظ تبدیل کرنے کی کوشش کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading result..."
msgstr "نتیجہ ڈاؤن لوڈ کیا جا رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Downloading image"
msgstr "تصویر ڈاؤن لوڈ کی جا رہی ہے"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You may need to reduce your settings or choose another model, or you may "
"have been censored. Horde message"
msgstr ""
"آپ کو اپنی ترتیبات کم کرنے یا کوئی اور ماڈل منتخب کرنے کی ضرورت ہو سکتی ہے، "
"یا آپ کو سنسر کیا گیا ہو سکتا ہے۔ ہورڈ (Horde) پیغام"

#: plugin/contrib/aihordeclient/__init__.py
msgid " generated by "
msgstr " تخلیق کردہ از "

#: plugin/contrib/aihordeclient/__init__.py
msgid " with "
msgstr " کے ساتھ "

