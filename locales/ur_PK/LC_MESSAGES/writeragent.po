msgstr ""
"=PYTHON() ڈیٹا یا Run Python Script ڈیٹا/data_range میں زیادہ سے زیادہ سیلز۔ "
"بڑی اقدار زیادہ RAM اور وقت استعمال کرتی ہیں؛ UNO رینج ریڈ اب بھی غالب ہے۔"

msgid "Python session mode"
msgstr "Python سیشن موڈ"

msgid ""
"Isolated: each =PYTHON() cell gets a fresh namespace. Shared: one namespace "
"per workbook (variables carry between cells)."
msgstr ""
"Isolated: ہر =PYTHON() سیل ایک نیا نیم اسپیس حاصل کرتا ہے۔ Shared: فی ورک بک "
"ایک نیم اسپیس (متغیرات سیلز کے درمیان منتقل ہوتے ہیں)۔"

msgid "Isolated (default)"
msgstr "Isolated (پہلے سے طے شدہ)"

