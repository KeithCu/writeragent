#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"دستاویزی تحقیق کے مطالعے کے لیے خصوصی ٹاسک ڈیلیگیشن (USE_SUB_AGENT) کی ضرورت"
" ہوتی ہے۔ اسے کنفیگریشن میں فعال کریں۔"

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "برین سٹارمنگ سیشن شروع ہو گیا۔"

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "برین سٹارمنگ سیشن مکمل ہو گیا۔"

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"برین سٹارمنگ کے لیے سائڈبار سیشن وائرنگ "
"(start_brainstorming_session_callback) درکار ہے۔"

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"ٹول کال '{0}' پر منتقل ہو گئی۔ آپ ایک خصوصی ٹول سیٹ موڈ میں ہیں۔ مکمل APIs "
"بحال کرنے کے لیے کام مکمل ہونے پر آپ کو 'specialized_workflow_finished' کال "
"کرنا ہوگا۔"

#: plugin/notebook/notebook_runner.py
msgid "Cell execution failed."
msgstr "سیل (Cell) پر عمل درآمد ناکام ہو گیا۔"

#: plugin/notebook/notebook_runner.py
msgid "Notebook run is only supported in LibreOffice Writer."
msgstr "نوٹ بک چلانا صرف LibreOffice Writer میں معاون ہے۔"

#: plugin/notebook/notebook_runner.py
msgid ""
"This document has no imported notebook. Use Tools → Import Jupyter Notebook…"
" first."
msgstr ""
"اس دستاویز میں کوئی درآمد شدہ نوٹ بک نہیں ہے۔ پہلے Tools → Import Jupyter "
"Notebook… استعمال کریں۔"

#: plugin/notebook/notebook_runner.py
msgid "Could not find notebook cell for this control."
msgstr "اس کنٹرول کے لیے نوٹ بک سیل نہیں مل سکا۔"

#: plugin/notebook/notebook_runner.py plugin/notebook/import_dialog.py
msgid "Open a Writer document first."
msgstr "پہلے ایک Writer دستاویز کھولیں۔"

#: plugin/notebook/import_dialog.py
msgid "Import Jupyter Notebook"
msgstr "Jupyter نوٹ بک درآمد کریں"

#: plugin/notebook/import_dialog.py
msgid "Jupyter Notebook"
msgstr "Jupyter نوٹ بک"

#: plugin/notebook/import_dialog.py
msgid "All files"
msgstr "تمام فائلیں"

#: plugin/notebook/import_dialog.py
msgid "Import Notebook is only supported in LibreOffice Writer."
msgstr "نوٹ بک درآمد کرنے کی سہولت صرف LibreOffice Writer میں دستیاب ہے۔"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid "Failed to import notebook: {error}"
msgstr "نوٹ بک درآمد کرنے میں ناکامی: {error}"

#: plugin/notebook/import_dialog.py
#, python-brace-format
msgid ""
"Imported notebook.\n"
"Cells: {cells} (code: {code}, markdown: {markdown})\n"
"Code input fields in document: {shapes}\n"
"Output images: {images}"
msgstr ""
"نوٹ بک درآمد ہو گئی۔\n"
"خلیات: {cells} (کوڈ: {code}، مارک ڈاؤن: {markdown})\n"
"دستاویز میں کوڈ ان پٹ فیلڈز: {shapes}\n"
"آؤٹ پٹ تصاویر: {images}"

#: plugin/notebook/writer_importer.py
msgid "Run code cell"
msgstr "کوڈ سیل چلائیں"

#: plugin/contrib/aihordeclient/__init__.py plugin/chatbot/panel.py
msgid "Starting..."
msgstr "شروع ہو رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Updating model requirements..."
msgstr "ماڈل کی ضروریات کو اپ ڈیٹ کیا جا رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Updating Models..."
msgstr "ماڈلز کو اپ ڈیٹ کیا جا رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Register at "
msgstr "یہاں رجسٹر کریں "

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "You have {} kudos"
msgstr "آپ کے پاس {} kudos ہیں"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "«{}» is not a valid API KEY, double check it or create a new one"
msgstr "«{}» ایک درست API KEY نہیں ہے، اسے دوبارہ چیک کریں یا ایک نیا بنائیں"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"At this moment we can not process your request, please try again later.  If "
"this is happening for a long period of time, please let us know via Discord"
msgstr ""
"اس وقت ہم آپ کی درخواست پر کارروائی نہیں کر سکتے، براہ کرم بعد میں دوبارہ "
"کوشش کریں۔ اگر یہ طویل عرصے سے ہو رہا ہے، تو براہ کرم ہمیں Discord کے ذریعے "
"مطلع کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Problem requesting kudos"
msgstr "kudos کی درخواست کرنے میں مسئلہ"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"The Horde is in maintenance mode, please try again later, if you have tried "
"and the service does not respond for hours, please contact via Discord"
msgstr ""
"Horde مینٹیننس موڈ میں ہے، براہ کرم بعد میں دوبارہ کوشش کریں، اگر آپ نے کوشش"
" کی ہے اور سروس گھنٹوں تک جواب نہیں دیتی ہے، تو براہ کرم Discord کے ذریعے "
"رابطہ کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You have made too many requests, please wait for them to finish, and try "
"again later"
msgstr ""
"آپ نے بہت زیادہ درخواستیں کی ہیں، براہ کرم ان کے مکمل ہونے کا انتظار کریں، "
"اور بعد میں دوبارہ کوشش کریں"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Seems that «{}» has problems, double check it, create a new one or join "
"Discord to ask for help"
msgstr ""
"ایسا لگتا ہے کہ «{}» میں مسائل ہیں، اسے دوبارہ چیک کریں، ایک نیا بنائیں یا "
"مدد کے لیے ڈسکارڈ (Discord) میں شامل ہوں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "We hit an error, still: "
msgstr "ہمیں ایک خرابی کا سامنا ہے، پھر بھی: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "No longer valid, please try again.  Your request took too long"
msgstr ""
"اب درست نہیں ہے، براہ کرم دوبارہ کوشش کریں۔ آپ کی درخواست میں بہت زیادہ وقت "
"لگا"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Contacting the Horde..."
msgstr "Horde سے رابطہ کیا جا رہا ہے..."

#: plugin/contrib/aihordeclient/__init__.py
msgid "Horde Contacted"
msgstr "Horde سے رابطہ ہو گیا"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"When trying to ask for the image, the Horde was too slow, try again later"
msgstr ""
"تصویر مانگنے کی کوشش کے دوران، Horde بہت سست تھا، بعد میں دوبارہ کوشش کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "to learn to earn kudos. Detail:"
msgstr "kudos کمانے کا طریقہ سیکھنے کے لیے۔ تفصیل:"

