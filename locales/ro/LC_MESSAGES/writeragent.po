msgstr "Păstrează grupurile de text orfane"

msgid "Group unassigned text into clusters for messy layouts."
msgstr "Grupează textul neatribuit în grupuri pentru machete dezordonate."

msgid "Document insert mode"
msgstr "Mod inserare document"

msgid ""
"html = Docling HTML import (default). structured = bbox column layout in "
"Writer; native Calc cells for extract_structure tables."
msgstr ""
"html = import HTML Docling (implicit). structured = aspect coloană bbox în "
"Writer; celule Calc native pentru tabele extract_structure."

msgid "Standard HTML"
msgstr "HTML standard"

msgid "Structured (layout / cell grid)"
msgstr "Structurat (aspect / grilă de celule)"

msgid "Layout model"
msgstr "Model de machetă"

msgid "Heron (default)"
msgstr "Heron (implicit)"

msgid "Egret large (slower"
msgstr "Egret mare (mai lent"

msgid "Extract formulas (LaTeX)"
msgstr "Extrage formule (LaTeX)"

