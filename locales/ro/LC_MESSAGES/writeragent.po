msgid "Docling artifacts path"
msgstr "Cale artefacte Docling"

msgid "Optional folder from docling-tools models download (offline use)."
msgstr ""
"Dosar opțional pentru descărcarea modelelor docling-tools (utilizare "
"offline)."

msgid "OCR confidence threshold"
msgstr "Prag de încredere OCR"

msgid "RapidOCR minimum text score. Raise to reduce garbage text."
msgstr ""
"Scor minim de text pentru RapidOCR. Creșteți pentru a reduce textul "
