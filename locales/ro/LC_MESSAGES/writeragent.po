msgstr "Opt-in. Descarcă modele VLM suplimentare la prima utilizare; mai lent."

msgid "Code block enrichment"
msgstr "Îmbogățire bloc de cod"

msgid "Specialized OCR for code/terminal screenshots."
msgstr "OCR specializat pentru capturi de ecran cu cod/terminal."

msgid "Docling document timeout (s)"
msgstr "Timp limită document Docling (s)"

msgid "Per-conversion timeout inside Docling. 0 = no limit."
msgstr "Timp limită per conversie în Docling. 0 = fără limită."
