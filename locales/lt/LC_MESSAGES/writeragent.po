msgstr ""
"Minimalus „RapidOCR“ teksto įvertis. Padidinkite, kad sumažintumėte "
"šiukšlinio teksto kiekį."

msgid "OCR entire image"
msgstr "Atpažinti visą vaizdą (OCR)"

msgid "Recommended for embedded graphics exported from LibreOffice."
msgstr "Rekomenduojama įterptajai grafikai, eksportuotai iš „LibreOffice“."

