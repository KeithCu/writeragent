msgstr "Struktūrinis (išdėstymas / langelių tinklelis)"

msgid "Layout model"
msgstr "Maketo modelis"

msgid "Heron (default)"
msgstr "Heron (numatytasis)"

msgid "Egret large (slower"
msgstr "Egret large (lėtesnis"

