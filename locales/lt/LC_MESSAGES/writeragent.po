msgid "Prompt for Web Research"
msgstr "Rodyti raginimą atlikti žiniatinklio tyrimą"

msgid "Ask for confirmation before sending a web search query"
msgstr "Prašyti patvirtinimo prieš siunčiant žiniatinklio paieškos užklausą"

msgid "Web Research Browser"
msgstr "Žiniatinklio tyrimų naršyklė"

msgid ""
"Select the browser backend to use for webpage visits during research (Off "
"uses static HTTP requests)."
msgstr ""
"Pasirinkite naršyklės pagrindinę programą, naudojamą lankantis "
"tinklalapiuose tyrimų metu („Išjungta“ naudoja statines HTTP užklausas)."

msgid "Off (Static HTTP)"
msgstr "Išjungta (statinis HTTP)"

msgid "Firefox (CDP)"
msgstr "„Firefox“ (CDP)"

msgid "Chromium (CDP)"
msgstr "„Chromium“ (CDP)"

