#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Dokumentų tyrimo užklausoms reikalingas specializuotas užduočių delegavimas "
"(USE_SUB_AGENT). Įgalinkite tai konfigūracijoje."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Įrankio iškvietimas perjungtas į „{0}“. Veikiate specializuoto įrankių "
"rinkinio režimu. Norėdami atkurti visą API rinkinį, baigę darbą turite "
"iškviesti „specialized_workflow_finished“."

