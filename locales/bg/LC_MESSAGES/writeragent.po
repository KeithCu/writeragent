" таблици с извлечена структура."

msgid "Standard HTML"
msgstr "Стандартен HTML"

msgid "Structured (layout / cell grid)"
msgstr "Структуриран (оформление / мрежа от клетки)"

msgid "Layout model"
msgstr "Модел на оформление"

msgid "Heron (default)"
msgstr "Heron (по подразбиране)"

msgid "Egret large (slower"
msgstr "Egret large (по-бавен"

msgid "Extract formulas (LaTeX)"
msgstr "Извличане на формули (LaTeX)"

msgid "Opt-in. Downloads extra VLM models on first use; slower."
msgstr ""
"Включване. Изтегля допълнителни VLM модели при първоначална употреба; по-"
"бавно."

msgid "Code block enrichment"
msgstr "Обогатяване на кодови блокове"

msgid "Specialized OCR for code/terminal screenshots."
msgstr "Специализиран OCR за екранни снимки на код/терминал."

msgid "Docling document timeout (s)"
msgstr "Таймаут за документи в Docling (сек.)"

msgid "Per-conversion timeout inside Docling. 0 = no limit."
msgstr "Таймаут за преобразуване в Docling. 0 = без ограничение."
