#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Dokumentresearch kræver specialiseret opgaveuddelegering (USE_SUB_AGENT). "
"Aktivér dette i konfigurationen."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Værktøjskald skiftet til '{0}'. Du er i en specialiseret værktøjstilstand. "
"Du skal kalde 'specialized_workflow_finished', når du er færdig, for at "
"gendanne det fulde sæt af API'er."

