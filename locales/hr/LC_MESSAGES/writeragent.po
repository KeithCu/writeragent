#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Čitanje istraživanja dokumenata zahtijeva delegiranje specijaliziranih "
"zadataka (USE_SUB_AGENT). Omogućite ovo u konfiguraciji."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "Sesija brainstorminga je započela."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "Sesija brainstorminga je završena."

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"Brainstorming zahtijeva povezivanje sesije na bočnoj traci "
"(start_brainstorming_session_callback)."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Poziv alata prebačen na '{0}'. Nalazite se u načinu rada specijaliziranog "
"alata. Morate pozvati 'specialized_workflow_finished' kada završite kako "
"biste vratili puni skup API-ja."

