msgstr ""
"Neobavezna mapa za preuzimanje docling-tools modela (izvanmrežna uporaba)."

msgid "OCR confidence threshold"
msgstr "Prag pouzdanosti OCR-a"

msgid "RapidOCR minimum text score. Raise to reduce garbage text."
msgstr ""
"Minimalni rezultat teksta za RapidOCR. Povećajte za smanjenje neželjenog "
