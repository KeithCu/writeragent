#: plugin/framework/constants.py
msgid ""
"AI: I can edit or translate your document instantly with professional "
"formatting and color. Try me!"
msgstr ""
"AI: Dokážem okamžite upraviť alebo preložiť váš dokument s profesionálnym "
"formátovaním a farbami. Vyskúšajte ma!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you with formulas, data analysis, and colorful charts. Try "
"me!"
msgstr ""
"AI: Pomôžem vám so vzorcami, analýzou údajov a farebnými grafmi. Vyskúšajte "
"ma!"

#: plugin/framework/constants.py
msgid ""
"AI: I can help you create and edit polished, colorful shapes in Draw and "
"Impress. Try me!"
msgstr ""
"AI: Pomôžem vám vytvárať a upravovať vyleštené, farebné tvary v aplikáciách "
"Draw a Impress. Vyskúšajte ma!"

#: plugin/framework/constants.py
msgid ""
"AI: I can do web research to answer any question, or summarize a web page, "
"without seeing or changing your document. Let's chat."
msgstr ""
"AI: Môžem vyhľadávať na webe a odpovedať na akúkoľvek otázku alebo zhrnúť "
"webovú stránku bez toho, aby som videl alebo menil váš dokument. Poďme "
"chatovať."

