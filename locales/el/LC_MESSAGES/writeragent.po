msgid "Invalid API Key. Please check your settings."
msgstr "Μη έγκυρο κλειδί API. Παρακαλούμε ελέγξτε τις ρυθμίσεις σας."

#: plugin/framework/client/errors.py
msgid "API access Forbidden. Your key may lack permissions for this model."
msgstr ""
"Απαγορευμένη πρόσβαση API. Το κλειδί σας ενδέχεται να μην έχει δικαιώματα "
"για αυτό το μοντέλο."

#: plugin/framework/client/errors.py
msgid "Endpoint not found (404). Check your URL and Model name."
msgstr ""
"Το τελικό σημείο (endpoint) δεν βρέθηκε (404). Ελέγξτε το URL και το όνομα "
"του μοντέλου σας."

#: plugin/framework/client/errors.py
#, python-brace-format
msgid "Server error ({0}). The AI provider is having issues."
msgstr "Σφάλμα διακομιστή ({0}). Ο πάροχος AI αντιμετωπίζει προβλήματα."

#: plugin/framework/client/errors.py
#, python-brace-format
msgid "HTTP Error {0}: {1}"
msgstr "Σφάλμα HTTP {0}: {1}"

#: plugin/framework/client/errors.py
msgid "Request Timed Out. Try increasing 'Request Timeout' in Settings."
msgstr ""
"Το αίτημα έληξε. Δοκιμάστε να αυξήσετε το «Χρονικό όριο αιτήματος» στις "
"Ρυθμίσεις."

#: plugin/framework/client/errors.py
msgid "Connection Refused. Is your local AI server (Ollama/LM Studio) running?"
