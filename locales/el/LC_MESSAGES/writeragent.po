#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must "
"call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Η κλήση εργαλείου άλλαξε σε '{0}'. Βρίσκεστε σε λειτουργία εξειδικευμένου "
"συνόλου εργαλείων. Πρέπει να καλέσετε το 'specialized_workflow_finished' "
"όταν τελειώσετε για να επαναφέρετε το πλήρες σύνολο των API."

#: plugin/contrib/aihordeclient/__init__.py plugin/chatbot/panel.py
msgid "Starting..."
