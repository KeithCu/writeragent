#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Odczyty badań dokumentów wymagają specjalistycznej delegacji zadań "
"(USE_SUB_AGENT). Włącz to w konfiguracji."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "Rozpoczęto sesję burzy mózgów."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "Zakończono sesję burzy mózgów."

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"Burza mózgów wymaga połączenia sesji paska bocznego "
"(start_brainstorming_session_callback)."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Wywołanie narzędzia przełączone na „{0}”. Jesteś w trybie specjalistycznego "
"zestawu narzędzi. Musisz wywołać „specialized_workflow_finished” po "
"zakończeniu, aby przywrócić pełny zestaw interfejsów API."

