msgstr "Ativar servidor MCP"

msgid ""
"Localhost only, no auth. Clients use http://localhost:<port>/mcp (streamable"
" HTTP)."
msgstr ""
"Apenas localhost, sem autenticação. Os clientes usam "
"http://localhost:<port>/mcp (HTTP com suporte a streaming)."

msgid "MCP Port"
msgstr "Porta MCP"

msgid "Allow CORS from local origins"
msgstr "Permitir CORS de origens locais"

msgid ""
"Automatic for .local, .lan, .home.arpa, .internal, .intern, and LAN IPs in "
"the browser Origin. For other hosts, add mcp.cors_allowed_origins in "
"writeragent.json."
msgstr ""
"Automático para .local, .lan, .home.arpa, .internal, .intern e IPs de LAN na"
" Origin do navegador. Para outros hosts, adicione mcp.cors_allowed_origins "
"em writeragent.json."

