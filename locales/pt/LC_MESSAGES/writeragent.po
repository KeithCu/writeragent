#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"As leituras de pesquisa de documentos requerem delegação de tarefas "
"especializada (USE_SUB_AGENT). Ative isto na configuração."

