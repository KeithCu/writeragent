#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"As leituras de pesquisa de documentos requerem delegação de subagente "
"(USE_SUB_AGENT). Ative os subagentes na configuração."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Chamada de ferramenta alterada para '{0}'. Você está em um modo de conjunto "
"de ferramentas especializado. Você deve chamar "
"'specialized_workflow_finished' ao terminar para restaurar o conjunto "
"completo de APIs."

