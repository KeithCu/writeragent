msgstr "Máximo de rodadas da ferramenta"

msgid "Document Context Strategy"
msgstr "Estratégia de contexto do documento"

msgid "How much document content to include in LLM context"
msgstr "Quanto conteúdo do documento incluir no contexto da LLM"

msgid "Auto (by document size)"
msgstr "Automático (pelo tamanho do documento)"

msgid "Full document text"
msgstr "Texto completo do documento"

