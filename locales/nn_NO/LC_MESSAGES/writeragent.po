#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Dokumentforsking krev spesialisert oppgåvedelegering (USE_SUB_AGENT). "
"Aktiver dette i oppsettet."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Verktøykall bytta til '{0}'. Du er i ein spesialisert verktøymodus. Du må "
"kalle 'specialized_workflow_finished' når du er ferdig for å gjenopprette "
"det fulle settet med API-ar."

