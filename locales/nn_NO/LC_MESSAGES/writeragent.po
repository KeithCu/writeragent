msgstr "Behald foreldrelause tekstklynger"

msgid "Group unassigned text into clusters for messy layouts."
msgstr "Grupper ufordelt tekst i klynger for rotete oppsett."

msgid "Document insert mode"
msgstr "Modus for dokumentinnsetjing"

msgid ""
"html = Docling HTML import (default). structured = bbox column layout in "
"Writer; native Calc cells for extract_structure tables."
msgstr ""
"html = Docling HTML-import (standard). structured = bbox-kolonneoppsett i "
"Writer; native Calc-celler for extract_structure-tabellar."

msgid "Standard HTML"
msgstr "Standard HTML"

msgid "Structured (layout / cell grid)"
msgstr "Strukturert (oppsett / cellerutenett)"

msgid "Layout model"
msgstr "Oppsettsmodell"

msgid "Heron (default)"
msgstr "Heron (standard)"

msgid "Egret large (slower"
msgstr "Egret stor (tregare"

msgid "Extract formulas (LaTeX)"
msgstr "Trekk ut formlar (LaTeX)"

msgid "Opt-in. Downloads extra VLM models on first use; slower."
msgstr "Samtykke. Lastar ned ekstra VLM-modellar ved første bruk; går saktare."

msgid "Code block enrichment"
msgstr "Utviding av kodeblokker"

msgid "Specialized OCR for code/terminal screenshots."
msgstr "Spesialisert OCR for skjermbilete av kode/terminal."

msgid "Docling document timeout (s)"
msgstr "Tidsavbrot for Docling-dokument (s)"

msgid "Per-conversion timeout inside Docling. 0 = no limit."
msgstr "Tidsavbrot per konvertering i Docling. 0 = inga grense."
