#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Для чтения результатов исследования документа требуется делегирование "
"специализированных задач (USE_SUB_AGENT). Включите эту функцию в настройках."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session started."
msgstr "Сеанс мозгового штурма начат."

#: plugin/doc/specialized_base.py
msgid "Brainstorming session completed."
msgstr "Сеанс мозгового штурма завершен."

#: plugin/doc/specialized_base.py
msgid ""
"Brainstorming requires sidebar session wiring "
"(start_brainstorming_session_callback)."
msgstr ""
"Для мозгового штурма требуется подключение сеанса боковой панели "
"(start_brainstorming_session_callback)."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Вызов инструмента переключен на «{0}». Вы находитесь в режиме "
"специализированного набора инструментов. Вы должны вызвать "
"«specialized_workflow_finished» по завершении, чтобы восстановить полный "
"набор API."

