msgstr "Авто (по размеру документа)"

msgid "Full document text"
msgstr "Полный текст документа"

msgid "Pages around cursor"
msgstr "Страницы вокруг курсора"

msgid "Outline + excerpt"
msgstr "Структура + фрагмент"

msgid "Stats + outline only"
msgstr "Статистика + только структура"

