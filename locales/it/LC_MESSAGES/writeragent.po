#: plugin/doc/specialized_base.py
msgid ""
"Local OCR requires Settings → Python venv with Docling or PaddleOCR "
"(Settings → Python → Test for install hints)."
msgstr ""
"L'OCR locale richiede Impostazioni → Python venv con Docling o PaddleOCR "
"(Impostazioni → Python → Verifica per suggerimenti sull'installazione)."

#: plugin/doc/specialized_base.py
msgid "Running local OCR on selected image..."
msgstr "Esecuzione OCR locale sull'immagine selezionata..."

#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT). "
"Enable this in configuration."
msgstr ""
"Le letture di ricerca documentale richiedono una delega specifica delle "
"attività (USE_SUB_AGENT). Abilitarla nella configurazione."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must "
"call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Chiamata allo strumento passata a '{0}'. Sei in una modalità set di "
"strumenti specializzati. Devi chiamare 'specialized_workflow_finished' al "
"termine per ripristinare il set completo di API."

