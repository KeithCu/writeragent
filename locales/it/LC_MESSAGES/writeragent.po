msgstr "Numero massimo di cicli dello strumento"

msgid "Document Context Strategy"
msgstr "Strategia di contesto del documento"

msgid "How much document content to include in LLM context"
msgstr "Quanto contenuto del documento includere nel contesto LLM"

msgid "Auto (by document size)"
msgstr "Automatico (in base alla dimensione del documento)"

msgid "Full document text"
msgstr "Testo completo del documento"

msgid "Pages around cursor"
msgstr "Pagine attorno al cursore"

msgid "Outline + excerpt"
msgstr "Struttura + estratto"

msgid "Stats + outline only"
msgstr "Solo statistiche + struttura"

