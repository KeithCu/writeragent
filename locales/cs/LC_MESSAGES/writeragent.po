#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require sub-agent delegation (USE_SUB_AGENT). Enable"
" sub-agents in configuration."
msgstr ""
"Čtení výzkumu dokumentu vyžaduje delegování na podřízeného agenta "
"(USE_SUB_AGENT). Povolte podřízené agenty v konfiguraci."

#: plugin/doc/specialized_base.py
#, python-brace-format
