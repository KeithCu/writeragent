#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Čtení dokumentů pro výzkum vyžaduje specializovanou delegaci úkolů "
"(USE_SUB_AGENT). Povolte toto v konfiguraci."

#: plugin/doc/specialized_base.py
#, python-brace-format
msgid ""
"Tool call switched to '{0}'. You are in a specialized toolset mode. You must"
" call 'specialized_workflow_finished' when done to restore the full set of "
"APIs."
msgstr ""
"Volání nástroje přepnuto na '{0}'. Jste ve speciálním režimu sady nástrojů. "
"Po dokončení musíte zavolat 'specialized_workflow_finished' pro obnovení "
"plné sady rozhraní API."

