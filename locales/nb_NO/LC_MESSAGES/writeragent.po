#: plugin/doc/specialized_base.py
msgid ""
"Document research reads require specialized task delegation (USE_SUB_AGENT)."
" Enable this in configuration."
msgstr ""
"Dokumentundersøkelser krever spesialisert oppgavedelegering (USE_SUB_AGENT)."
" Aktiver dette i konfigurasjonen."

#: plugin/doc/specialized_base.py
#, python-brace-format
