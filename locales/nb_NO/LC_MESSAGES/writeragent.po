msgstr "Kun statistikk + disposisjon"

msgid "Web Research Cache"
msgstr "Web-undersøkelsesbuffer"

msgid ""
"Cache completed web research reports by normalized query (uses web cache "
"database)."
msgstr ""
"Mellomlagre fullførte nettforskningsrapporter etter normalisert spørring "
"(bruker database for nett-mellomlager)."

msgid "Prompt for Web Research"
msgstr "Spør om nettsøk"

msgid "Ask for confirmation before sending a web search query"
msgstr "Be om bekreftelse før et nettsøk sendes"

msgid "Web Research Browser"
msgstr "Nettleser for nettforskning"

msgid ""
"Select the browser backend to use for webpage visits during research (Off "
"uses static HTTP requests)."
msgstr ""
"Velg nettleser-backend som skal brukes for nettsidebesøk under forskning (Av"
" bruker statiske HTTP-forespørsler)."

