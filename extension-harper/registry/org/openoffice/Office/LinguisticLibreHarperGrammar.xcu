<?xml version="1.0" encoding="UTF-8"?>
<!-- Locales must match HARPER_LOCALE_TAGS in plugin/writer/locale/harper_proofreader.py. -->
<oor:component-data oor:name="Linguistic"
        oor:package="org.openoffice.Office" xmlns:oor="http://openoffice.org/2001/registry"
        xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <node oor:name="ServiceManager">
        <node oor:name="GrammarCheckers">
            <node oor:name="org.extension.libreharper.comp.pyuno.HarperProofreader" oor:op="fuse">
                <prop oor:name="Locales" oor:type="oor:string-list">
                    <value>en-US en-GB en-AU en-CA en-IN</value>
                </prop>
            </node>
        </node>
    </node>
</oor:component-data>
