msgstr "MCP"

msgid "Enable MCP Server"
msgstr "Aktivér MCP-server"

msgid "Localhost only, no auth. Access via stdio is always enabled."
msgstr "Kun localhost, ingen godkendelse. Adgang via stdio er altid aktiveret."

