msgid "Path / URL"
msgstr "Percorso / URL"

msgid ""
"Path to backend CLI (e.g. aider) or ACP server URL (e.g. http://"
"localhost:8000 for Hermes). Empty = try default."
msgstr ""
"Percorso verso la CLI del backend (es. aider) o URL del server ACP (es. "
"http://localhost:8000 per Hermes). Vuoto = prova il predefinito."

msgid "Extra arguments"
msgstr "Argomenti extra"

msgid "Optional arguments for the selected backend (space-separated)."
msgstr "Argomenti opzionali per il backend selezionato (separati da spazi)."

msgid "ACP agent name"
msgstr "Nome agente ACP"

msgid ""
"Agent name on the ACP server (e.g. hermes). Empty = auto-discover first "
"agent."
msgstr ""
"Nome dell'agente sul server ACP (es. hermes). Vuoto = rileva automaticamente "
"il primo agente."

