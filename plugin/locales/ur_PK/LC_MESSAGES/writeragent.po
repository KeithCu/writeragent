#: plugin/contrib/aihordeclient/__init__.py
msgid "Register at "
msgstr "یہاں رجسٹر کریں "

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "You have {} kudos"
msgstr "آپ کے پاس {} kudos ہیں"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid "«{}» is not a valid API KEY, double check it or create a new one"
msgstr "«{}» ایک درست API KEY نہیں ہے، اسے دوبارہ چیک کریں یا ایک نیا بنائیں"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"At this moment we can not process your request, please try again later.  If "
"this is happening for a long period of time, please let us know via Discord"
msgstr ""
"اس وقت ہم آپ کی درخواست پر کارروائی نہیں کر سکتے، براہ کرم بعد میں دوبارہ "
"کوشش کریں۔ اگر یہ طویل عرصے سے ہو رہا ہے، تو براہ کرم ہمیں Discord کے ذریعے "
"مطلع کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "Problem requesting kudos"
msgstr "kudos کی درخواست کرنے میں مسئلہ"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"The Horde is in maintenance mode, please try again later, if you have tried "
"and the service does not respond for hours, please contact via Discord"
msgstr ""
"Horde مینٹیننس موڈ میں ہے، براہ کرم بعد میں دوبارہ کوشش کریں، اگر آپ نے کوشش "
"کی ہے اور سروس گھنٹوں تک جواب نہیں دیتی ہے، تو براہ کرم Discord کے ذریعے "
"رابطہ کریں"

#: plugin/contrib/aihordeclient/__init__.py
msgid ""
"You have made too many requests, please wait for them to finish, and try "
"again later"
msgstr ""
"آپ نے بہت زیادہ درخواستیں کی ہیں، براہ کرم ان کے مکمل ہونے کا انتظار کریں، "
"اور بعد میں دوبارہ کوشش کریں"

#: plugin/contrib/aihordeclient/__init__.py
#, python-brace-format
msgid ""
"Seems that «{}» has problems, double check it, create a new one or join "
"Discord to ask for help"
msgstr ""
"ایسا لگتا ہے کہ «{}» میں مسائل ہیں، اسے دوبارہ چیک کریں، ایک نیا بنائیں یا "
"مدد کے لیے ڈسکارڈ (Discord) میں شامل ہوں"

#: plugin/contrib/aihordeclient/__init__.py
msgid "We hit an error, still: "
msgstr "ہمیں ایک خرابی کا سامنا ہے، پھر بھی: "

#: plugin/contrib/aihordeclient/__init__.py
msgid "No longer valid, please try again.  Your request took too long"
msgstr ""
"اب درست نہیں ہے، براہ کرم دوبارہ کوشش کریں۔ آپ کی درخواست میں بہت زیادہ وقت "
"لگا"

