msgid "Path / URL"
msgstr "Caminho / URL"

msgid ""
"Path to backend CLI (e.g. aider) or ACP server URL (e.g. http://"
"localhost:8000 for Hermes). Empty = try default."
msgstr ""
"Caminho para a CLI do backend (ex: aider) ou URL do servidor ACP (ex: http://"
"localhost:8000 para o Hermes). Vazio = tentar o padrão."

msgid "Extra arguments"
msgstr "Argumentos extras"

msgid "Optional arguments for the selected backend (space-separated)."
msgstr ""
"Argumentos opcionais para o backend selecionado (separados por espaço)."

msgid "ACP agent name"
msgstr "Nome do agente ACP"

msgid ""
"Agent name on the ACP server (e.g. hermes). Empty = auto-discover first "
"agent."
msgstr ""
"Nome do agente no servidor ACP (ex: hermes). Vazio = autodescobrir o "
"primeiro agente."

