msgstr "आउटलाइन + अंश"

msgid "Stats + outline only"
msgstr "केवल आँकड़े + आउटलाइन"

msgid "Extend Selection Max Tokens"
msgstr "चयनित अधिकतम टोकन बढ़ाएं"

msgid "Edit Selection Extra Tokens"
msgstr "अतिरिक्त चयन टोकन संपादित करें"

